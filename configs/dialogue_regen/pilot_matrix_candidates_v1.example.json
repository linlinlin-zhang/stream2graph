{
  "output_dir": "artifacts/dialogue_regen/materialized/pilot_candidates_v1",
  "base": {
    "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
    "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
    "split": "validation",
    "target_language": "zh-CN",
    "max_samples": 100,
    "temperature": 0.2,
    "max_output_tokens": 4096,
    "max_tokens": 4096,
    "timeout_sec": 180,
    "max_retries": 5,
    "retry_backoff_sec": 3.0,
    "request_interval_sec": 1.0
  },
  "runs": [
    {
      "name": "gpt_4_1_pilot",
      "provider": "openai_responses",
      "model": "gpt-4.1",
      "api_key_env": "OPENAI_API_KEY"
    },
    {
      "name": "gemini_2_5_pro_pilot",
      "provider": "google_generate_content",
      "model": "gemini-2.5-pro",
      "api_key_env": "GOOGLE_API_KEY",
      "thinking_budget": 0
    },
    {
      "name": "deepseek_chat_pilot",
      "provider": "deepseek_chat_completions",
      "provider_name": "deepseek_chat_completions",
      "model": "deepseek-chat",
      "endpoint": "https://api.deepseek.com/chat/completions",
      "api_key_env": "DEEPSEEK_API_KEY"
    },
    {
      "name": "qwen3_max_pilot",
      "provider": "dashscope_chat_completions",
      "provider_name": "dashscope_chat_completions",
      "model": "qwen3-max",
      "endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions",
      "api_key_env": "DASHSCOPE_API_KEY"
    }
  ]
}

