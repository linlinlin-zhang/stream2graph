{
  "provider": "moonshot_chat_completions",
  "model": "kimi-k2.5",
  "endpoint": "https://api.moonshot.cn/v1/chat/completions",
  "split": "test",
  "max_samples": 0,
  "api_key_env": "MOONSHOT_API_KEY",
  "api_key": "",
  "temperature": 1.0,
  "omit_temperature": true,
  "max_new_tokens": 16384,
  "timeout_sec": 180,
  "max_retries": 6,
  "retry_backoff_sec": 5.0,
  "request_interval_sec": 0.015,
  "max_concurrency": 160,
  "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v7_kimi_k25_fullregen_strict_20260313",
  "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v7_kimi_k25_fullregen_strict_20260313/splits",
  "compile_command": "mmdc -i \"{input}\" -o \"{output}\"",
  "run_name": "moonshot_kimi_k25_v7_test_full",
  "output_root": "reports/evaluation/runs/openai_compatible",
  "publish_bundle": false,
  "published_dir": "reports/evaluation/published",
  "notes": "Formal full-test config for Moonshot Kimi K2.5 on the V7 strict Kimi-regenerated benchmark. Uses provider-default reasoning with an 80% RPM target and max concurrency 160."
}
