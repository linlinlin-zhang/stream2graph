  "code": "---\ntitle: \"Timescape Viewer\"\n---\nerDiagram\n    Timescape[\"Timescape Viewer\"] {\n        string title\n    }\n\n    Origin {\n        String name\n    }\n\n    ScopeLegend {\n    }\n\n    ScopePlotter {\n    }\n\n    Window {\n        Timestamp begin\n        Timestamp end\n        LiveMode live\n    }\n\n    Timescape ||--o{ Origin: origins\n    Timescape ||--o{ ScopeLegend: n\n    Timescape ||--o{ ScopePlotter: \"n*m\"\n    Timescape ||--o{ Window: m\n\n    Signal {\n        String name\n        String description\n        String unit\n    }\n\n    ScopePlotter }o..o{ Signal: \"shows\"\n    Origin ||..|{ Signal: \"owns\"\n\n    Run {\n        String title\n    }\n\n    Origin ||..|{ Run: \"consists of\"\n    Window }o..|| Run: \"shows\"\n\n    Track {\n        dummy value\n    }\n\n    Run ||--|{ Track: \"has\"\n    Track ||..|{ Signal: \"has\"\n\n    Block {\n        Date begin\n        Date end\n        double[] timestamps\n        double[][] values\n    }\n\n    Track ||--o{ Block: \"has\"\n",
