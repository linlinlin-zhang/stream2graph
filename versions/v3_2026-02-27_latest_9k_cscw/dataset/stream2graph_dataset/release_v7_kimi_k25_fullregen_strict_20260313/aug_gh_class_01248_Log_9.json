    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "没错，Request出去，Response回来。另外底层还有个HTTP连接，用虚线表示，也是Sdk连到Api。",
      "elements_involved": [
        "CustomSdk",
        "CustomApi",
        "HTTP connection"
