    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "错误状态可以恢复，我们有个TryRecoverErrorCMD命令能把错误订单修复到已完成。取消确实只能在处理中阶段，用CancelOrderCMD。另外还有个特殊情况——处理中尝试完成时如果失败，也会进入错误状态。",
      "elements_involved": [
        "state_OrderError",
        "state_OrderCompleted",
        "tryrecovererrorcmd",
        "cancelordercmd",
        "markordercompletecmd"
