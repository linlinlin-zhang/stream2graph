  "code": "%%{IoT_Industrial_MQTT_Broker}}}%%\nflowchart LR\n    %% COLOR STYLES\n    classDef clientAction fill:#90EE90,stroke:#333,stroke-width:2px,color:#000\n    classDef meeting fill:#87CEEB,stroke:#333,stroke-width:2px,color:#000\n    classDef premium fill:#FFB6C1,stroke:#333,stroke-width:2px,color:#000\n    classDef standard fill:#FFF,stroke:#333,stroke-width:2px,color:#000\n    classDef legendBox fill:#F5F5F5,stroke:#666,stroke-width:1px,color:#333\n\n    %% LEGEND\n    subgraph Legend[IoT_Industrial_ActuatorController]\n        direction TB\n        LegendTitle[IoT_Industrial_ActuatorController]:::legendBox\n        L1[IoT_Industrial_PLC_Logic]:::clientAction\n        L2[IoT_Industrial_MQTT_Broker]:::meeting\n        L3[IoT_Industrial_EdgeNode]:::premium\n        L4[IoT_Industrial_PLC_Logic]:::standard\n        LegendTitle ~~~ L1 ~~~ L2 ~~~ L3 ~~~ L4\n    end\n\n    %% STAGE 1: ONBOARDING\n    subgraph Stage1[IoT_Industrial_MQTT_Broker]\n        direction TB\n        Stage1Title[IoT_Industrial_EdgeNode]:::legendBox\n        S1[IoT_Industrial_ActuatorController]:::clientAction\n        S2[IoT_Industrial_PLC_Logic]:::standard\n        S3[IoT_Industrial_MQTT_Broker]:::standard\n        S4[IoT_Industrial_PLC_Logic]:::standard\n        S5[IoT_Industrial_TelemetryStream]:::clientAction\n        S6[IoT_Industrial_MQTT_Broker]:::meeting\n        Stage1Title ~~~ S1 --> S2 --> S3 --> S4 --> S5 --> S6\n    end\n\n    %% STAGE 2: DOCUMENT PREP\n    subgraph Stage2[IoT_Industrial_EdgeNode]\n        direction TB\n        Stage2Title[IoT_Industrial_PLC_Logic]:::legendBox\n        S7[IoT_Industrial_EdgeNode]:::standard\n        S8[IoT_Industrial_ActuatorController]:::standard\n        S9[IoT_Industrial_ActuatorController]:::clientAction\n        S10[IoT_Industrial_ActuatorController]:::standard\n        S11[IoT_Industrial_TelemetryStream]:::standard\n        S12[IoT_Industrial_MQTT_Broker]:::standard\n        S13[IoT_Industrial_TelemetryStream]:::meeting\n        Stage2Tit