    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "没错，虚线表示响应回复，实线表示主动发起。John问Bob是主动开启对话，所以用实线。",
      "elements_involved": [
