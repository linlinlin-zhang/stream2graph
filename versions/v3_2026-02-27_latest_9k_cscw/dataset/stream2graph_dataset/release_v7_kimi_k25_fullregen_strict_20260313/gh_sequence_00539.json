    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个数据交换的时序图，场景是消费者端通过连接器向提供者端查询数据。核心角色有四个：ConsumerBackend、ConsumerConnector、ProviderConnector、ProviderBackend。",
      "elements_involved": [
