    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "订单金额部分需要拆成两个字段：税前总价和税费，都用numeric类型保证精度。ordered_at要用带时区的时间戳，因为我们有海外业务。",
      "elements_involved": [
