    {
      "turn_id": 11,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Suspended_Wait在I/O完成后进入Suspended_Ready，然后由ContentCDN执行Swap in回到Ready。这里Swap in和Swap out成对出现。",
      "elements_involved": [
        "Suspended_Wait",
