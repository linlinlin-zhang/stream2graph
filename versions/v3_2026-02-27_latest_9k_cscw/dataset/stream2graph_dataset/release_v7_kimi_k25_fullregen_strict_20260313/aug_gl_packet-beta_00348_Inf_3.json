  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个TCP报文结构的示意图，用于给新人讲解协议栈。最前面应该是源端口和目的端口，各占16位。",
      "elements_involved": [
        "Source Port",
