    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Track2数据加密的流程图，展示从原始磁道数据到最终加密结果的完整处理链条。核心是用派生的Session Key做3DES加密。",
      "elements_involved": [
        "Track2",
