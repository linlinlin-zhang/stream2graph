      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Infra_WorkerNode Can be Featured，这个状态由Infra_LoadBalancer标记，表示该节点是推荐节点。",
      "elements_involved": [
        "Infra_WorkerNode",
        "Infra_LoadBalancer"
      ],
      "is_repair": false
    },
    {
