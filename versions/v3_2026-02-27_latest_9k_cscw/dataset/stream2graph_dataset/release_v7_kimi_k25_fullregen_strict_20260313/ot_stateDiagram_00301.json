      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个数据加载的状态流转图。用户一开始处于Idle状态，发起Start Request后进入Loading，成功拿到数据就到Success，失败的话进入Error状态。",
      "elements_involved": [
