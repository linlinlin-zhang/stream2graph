    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Signal和ScopePlotter是多对多关系，plotter可以显示多个signal，一个signal也能被多个plotter展示。关系命名为shows。",
      "elements_involved": [
        "Signal",
        "ScopePlotter",
        "shows"
