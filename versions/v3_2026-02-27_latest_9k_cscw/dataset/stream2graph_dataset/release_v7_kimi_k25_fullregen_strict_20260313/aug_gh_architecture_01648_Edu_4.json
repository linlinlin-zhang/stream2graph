      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要设计一个教育系统的架构图，核心是要体现内容分发、课堂服务和成绩同步这三个模块的交互关系。",
      "elements_involved": [
