      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个日程管理系统的时序图，核心流程是用户添加事件、设置提醒、以及查看事件。参与者包括User、SchedulerApp、Event、EventDAO、Reminder和ReminderService。",
      "elements_involved": [
        "User",
