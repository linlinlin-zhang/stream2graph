    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个基础设施的数据流图，核心是从入口控制器开始，经过负载均衡器和Redis缓存，最后回到入口控制器。",
      "elements_involved": [
        "Infra_IngressController",
        "Infra_LoadBalancer",
