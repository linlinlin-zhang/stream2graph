    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "propose",
      "utterance": "InProgress还有Pause到OnHold的分支。OnHold内部需要体现EMR_Sync的场景，包含Blocked和Deferred两种挂起原因。",
      "elements_involved": [
        "InProgress",
