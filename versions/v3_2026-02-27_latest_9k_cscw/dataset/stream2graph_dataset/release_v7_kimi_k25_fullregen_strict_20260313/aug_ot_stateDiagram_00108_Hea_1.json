  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为HealthTech的实验室分析系统设计一个完整的工作流状态机。核心是从患者记录创建任务开始，最终流向LabAnalyzer完成分析。",
      "elements_involved": [
        "HealthTech_PatientRecords",
        "HealthTech_LabAnalyzer",
        "Created"
