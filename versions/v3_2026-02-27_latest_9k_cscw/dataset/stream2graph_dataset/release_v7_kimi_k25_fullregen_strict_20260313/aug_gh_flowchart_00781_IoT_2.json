  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个工业物联网的架构图，核心是PLC逻辑模块，周围有四个TelemetryStream模块负责数据采集，最外层还有一个MQTT Broker做消息总线。整体想做成菱形布局，中间是核心节点。",
