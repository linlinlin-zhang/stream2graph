    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错，T25ms这里要用IoT_Industrial_TelemetryStream，12ms查余额，15ms预留资金。这两个操作加起来，加上前面的，同步阶段总共40ms。",
      "elements_involved": [
        "T25ms",
        "IoT_Industrial_TelemetryStream",
