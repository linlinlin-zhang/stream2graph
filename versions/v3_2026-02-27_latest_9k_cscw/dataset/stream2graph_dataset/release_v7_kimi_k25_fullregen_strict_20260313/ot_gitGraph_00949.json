      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，feature分支的order设为0，主分支默认是1，这样feature会显示在左边。提交标签要显示，每个commit都标上id。",
      "elements_involved": [
        "feature order: 0",
        "mainBranchOrder: 1",
