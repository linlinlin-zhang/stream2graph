    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "TrackingNumber之后要校验单号有效性，所以再到一个TrackingNumber节点做验证处理，然后分出Valid和Invalid两条路。",
      "elements_involved": [
        "Logistics_TrackingNumber",
