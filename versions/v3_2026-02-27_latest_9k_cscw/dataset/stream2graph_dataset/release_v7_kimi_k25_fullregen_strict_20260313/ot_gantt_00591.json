  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个甘特图来展示2014年初的项目安排。有两个主要阶段，每个阶段包含两个任务。标题我想带点特殊符号测试一下，用分号和井号这种。",
      "elements_involved": [
