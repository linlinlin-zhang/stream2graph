  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Git流程图，展示主分支main和功能分支feature的交互过程。先从main分支的初始提交a开始，然后分出feature分支。",
      "elements_involved": [
