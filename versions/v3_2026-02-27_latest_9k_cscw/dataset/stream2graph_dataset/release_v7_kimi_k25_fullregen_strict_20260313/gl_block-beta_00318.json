    {
      "turn_id": 17,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Block_NDIS暂时不用单独画回路，但我们要加一个optional的反馈：从Inpatient画一条虚线回到ED_Treat，标注\"high occupancy limits flow\"。表示住院部满了之后，急诊的病人也收不进去。",
      "elements_involved": [
        "Inpatient",
        "ED_Treat",
        "optional"
