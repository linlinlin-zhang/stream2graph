  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个自动化产线控制系统的状态图。系统启动后先进入空闲状态，然后操作员加载程序时会进入加载中状态。",
      "elements_involved": [
        "Idle",
        "Loading",
        "Load Program"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白了，Idle到Loading的触发条件是Load Program。那加载完成后呢？直接进入运行状态吗？",
      "elements_involved": [
        "Idle",
        "Loading",
        "Load Program"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "不是，加载完成后要先验证程序。验证通过才能到就绪状态，验证失败则进入错误状态。这个验证环节很重要，不能跳过。",
      "elements_involved": [
        "Loading",
        "Validating",
        "Ready",
        "Error",
        "Program Loaded",
        "Program Valid",
        "Invalid Program"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，所以Validating有两个出口：验证成功到Ready，失败到Error。从Ready开始运行后，运行状态应该支持暂停功能吧？",
      "elements_involved": [
        "Validating",
        "Ready",
        "Error",
        "Running",
        "Paused"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，Running可以响应Pause Command进入Paused，也能从Paused通过Resume Command恢复运行。另外还有一个特殊状态——Dressing，这是设备需要人工着装的环节。",
      "elements_involved": [
        "Running",
        "Paused",
        "Dressing",
        "Pause Command",
        "Resume Command",
        "Dress Required",
        "Dress Complete"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已经加上了Running和Dressing之间的双向转换。程序正常结束应该有个完成状态吧？",
      "elements_involved": [
        "Running",
        "Dressing",
        "Complete",
        "Program End"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "是的，Running到Complete是Program End触发。最后需要两个复位路径：Complete完成后回到Idle，Error状态清除后也回到Idle。",
      "elements_involved": [
        "Complete",
        "Error",
        "Idle",
        "Reset",
        "Clear Error"
      ],
      "is_repair": false
    },
    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "检查一遍：初始状态指向Idle，经过Loading、Validating到Ready，然后Running支持暂停和Dressing，最终Complete或Error都能回到Idle。结构完整了。",
      "elements_involved": [
        "[*]",
        "Idle",
