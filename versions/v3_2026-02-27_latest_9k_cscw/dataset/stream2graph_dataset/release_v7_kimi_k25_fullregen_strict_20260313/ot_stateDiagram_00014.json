  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个状态图，描述用户从发现网络到执行计算的完整流程。起点是初始状态，首先进入Discover状态，然后用户选择网络SelezionaRete。",
      "elements_involved": [
        "[*]",
        "Discover",
        "SelezionaRete"
