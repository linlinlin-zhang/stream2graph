    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，Pending通过MarkAsProcessingCMD转到Processing。Processing到Completed确实是MarkOrderCompleteCMD。但CancelOrderCMD只能在Processing阶段触发，一旦取消就进入Cancelled终态。",
      "elements_involved": [
        "state_OrderPending",
        "state_OrderProcessing",
        "state_OrderCompleted",
        "state_OrderCancelled",
        "MarkAsProcessingCMD",
        "MarkOrderCompleteCMD",
