  "code": "%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4e8', 'primaryTextColor': '#000', 'primaryBorderColor': '#228B22', 'lineColor': '#404040', 'secondaryColor': '#f5f5f5', 'tertiaryColor': '#fff'}}}%%\nstateDiagram-v2\n    [*] --> IDLE\n    IDLE --> FETCH: Kick-off\n    FETCH --> PARSE: Complete\n    PARSE --> ARB_READ: Valid\n    PARSE --> ERROR: Invalid\n    ARB_READ --> READ: Grant\n    READ --> ARB_WRITE: Complete\n    ARB_WRITE --> WRITE: Grant\n    WRITE --> CHAIN: Complete\n    CHAIN --> FETCH: Next\n    CHAIN --> COMPLETE: Last\n    COMPLETE --> IDLE: IRQ sent\n    ERROR --> IDLE: SW clear\n",
