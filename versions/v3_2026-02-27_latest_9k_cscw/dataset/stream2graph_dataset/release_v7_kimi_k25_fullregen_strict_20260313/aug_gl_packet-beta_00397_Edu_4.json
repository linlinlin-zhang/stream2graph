  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为教育场景设计一个数据包结构图，用来展示智慧校园系统中不同服务模块在802.11帧格式里的映射关系。核心系统包括GradeSync成绩同步、ClassroomService课堂服务、StudentDB学生数据库、ContentCDN内容分发，还有LMS Portal学习管理平台。",
      "elements_involved": [
        "Education_GradeSync",
        "Education_ClassroomService",
        "Education_StudentDB",
        "Education_ContentCDN",
        "Education_LMS_Portal",
        "Frame Control",
