      "role": "Domain_Expert",
      "action_type": "clarify",
      "utterance": "等等，\"Update Score\"和\"Show Correct Answer\"之后都要连到\"More Questions?\"，这个汇聚关系要画清楚。",
      "elements_involved": [
        "Update Score",
        "Show Correct Answer",
        "More Questions?"
      ],
      "is_repair": false
