  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要设计一个问答游戏的流程图。核心流程是：开始游戏后显示题目，获取用户答案，然后判断对错。",
      "elements_involved": [
        "Start Game",
        "Display Question",
        "Get User Answer",
        "Is Answer Correct?"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白。那判断答案之后，答对和答错分别怎么处理？",
      "elements_involved": [
        "Is Answer Correct?"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "答对的话更新分数，答错的话显示正确答案。然后两种情况都要判断还有没有更多题目。",
      "elements_involved": [
        "Update Score",
        "Show Correct Answer",
        "More Questions?"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，所以\"Update Score\"和\"Show Correct Answer\"都会汇聚到\"More Questions?\"这个判断节点，对吗？",
      "elements_involved": [
        "Update Score",
        "Show Correct Answer",
        "More Questions?"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，汇聚到同一个判断点。如果还有更多题目，就回到\"Display Question\"继续循环；没有就结束游戏。",
      "elements_involved": [
        "More Questions?",
        "Display Question",
        "End Game"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "我来画一下。起点是\"Start Game\"，然后到\"Display Question\"，再到\"Get User Answer\"，接着是菱形判断\"Is Answer Correct?\"。",
      "elements_involved": [
        "Start Game",
        "Display Question",
        "Get User Answer",
        "Is Answer Correct?"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "判断节点分出两条支路：Yes到\"Update Score\"，No到\"Show Correct Answer\"。",
      "elements_involved": [
        "Is Answer Correct?",
        "Update Score",
        "Show Correct Answer"
      ],
      "is_repair": false
