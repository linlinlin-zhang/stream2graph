    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "propose",
      "utterance": "考虑健壮性，启动和监控阶段如果信号异常怎么办？比如EEG没检测到，或者ADC饱和、噪声过大。",
      "elements_involved": [
