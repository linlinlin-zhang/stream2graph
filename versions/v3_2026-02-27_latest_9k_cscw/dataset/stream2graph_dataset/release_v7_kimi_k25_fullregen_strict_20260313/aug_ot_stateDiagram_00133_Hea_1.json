    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "ready flag被清除时就回到RUN。另外需要HOLD暂停机制：RUN状态由LabAnalyzer触发HOLD，READY状态由DiagnosticEngine自身触发HOLD。",
