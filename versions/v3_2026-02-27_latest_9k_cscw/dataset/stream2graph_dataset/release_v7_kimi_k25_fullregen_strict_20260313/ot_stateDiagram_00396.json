      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个AXI写通道的状态机。初始状态是IDLE，当AW握手成功，也就是AWVALID和AWREADY同时为高时，就进入WRITING状态。",
      "elements_involved": [
        "IDLE",
        "WRITING",
        "AWVALID && AWREADY"
