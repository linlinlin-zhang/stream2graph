      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Week 2做Video Content，1月8号开始拍三天；Newsletter安排在11号发，准备两天。然后Week 3播客Podcast录制四天，从15号开始，最后Infographic收尾，19号启动做两天。",
      "elements_involved": [
