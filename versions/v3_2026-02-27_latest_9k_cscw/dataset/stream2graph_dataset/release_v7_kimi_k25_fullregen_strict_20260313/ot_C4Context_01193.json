  "code": "C4Context\n    title System Context Diagram - MyFitnessFriend\n\n    Person(user, \"User\", \"Tracks meals, water, workouts, and views progress\")\n\n    System(mff, \"MyFitnessFriend\", \"Fitness & nutrition tracking platform for web and mobile\")\n\n    System_Ext(clerk, \"Clerk\", \"Google OAuth identity provider, JWT issuance\")\n    System_Ext(foodApi, \"Food Database API\", \"External food/nutrition data (e.g., Edamam)\")\n\n    Rel(user, mff, \"Logs meals, water, workouts; views diary & streaks\")\n    Rel(mff, clerk, \"Validates JWT tokens, retrieves user identity\")\n    Rel(mff, foodApi, \"Searches foods, resolves barcodes\")\n    Rel(user, clerk, \"Authenticates via Google OAuth\")",
