  "code": "%%{init: {\n  \"theme\": \"base\",\n  \"flowchart\": { \"curve\": \"basis\", \"nodeSpacing\": 60, \"rankSpacing\": 85, \"padding\": 10 },\n  \"themeVariables\": {\n    \"fontFamily\": \"Inter, Arial, sans-serif\",\n    \"fontSize\": \"14px\",\n    \"lineColor\": \"#333333\",\n    \"textColor\": \"#111111\"\n  }\n}}%%\n\nflowchart TB\n subgraph C[\"Commonwealth responsibility (revenue & policy levers)\"]\n    direction TB\n        Tax[\"Tax / Revenue\"]\n        MBS[\"Medicare (MBS)\"]\n        GP[\"General practice policy\"]\n        AgedCare[\"Aged care (places, pricing, market settings)\"]\n        NDIS[\"NDIS (supports, plans, providers)\"]\n  end\n subgraph F[\"Interface friction (cost shifting / system gaps)\"]\n    direction TB\n        Gap1[\"Primary care access gap\"]\n        Gap2[\"Aged care capacity constraint\"]\n        Gap3[\"NDIS supports delay / mismatch\"]\n        ED_Pres[\"ED presentations (avoidable demand)\"]\n        Bed_Occ[\"Bed occupancy pressure (long-stay)\"]\n  end\n subgraph S[\"State responsibility (operational delivery & risk)\"]\n    direction TB\n        Hosp_Budget[\"State hospital budgets\"]\n        ED[\"Emergency Department\"]\n        Wards[\"Inpatient wards\"]\n        Amb[\"Ambulance / ramping\"]\n  end\n    Tax -- NHRA grants (capped / constrained growth) --> Hosp_Budget\n    MBS -. service availability & affordability .-> Gap1\n    GP -. workforce / access .-> Gap1\n    AgedCare -. capacity / eligibility .-> Gap2\n    NDIS -. supports timing & fit .-> Gap3\n    Gap1 -- shift --> ED_Pres\n    Gap2 -- shift --> Bed_Occ\n    Gap3 -- shift --> Bed_Occ\n    ED_Pres -- demand surge --> ED\n    Bed_Occ -- delayed discharge --> Wards\n    ED -- ambulance holding --> Amb\n\n     Tax:::cth\n     MBS:::cth\n     GP:::cth\n     AgedCare:::cth\n     NDIS:::cth\n     Gap1:::risk\n     Gap2:::risk\n     Gap3:::risk\n     ED_Pres:::risk\n     Bed_Occ:::risk\n     Hosp_Budget:::state\n     ED:::state\n     Wards:::state\n     Amb:::state\n    classDef cth fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#111\n    classDef state fill:#ffebee,stroke:#b71c1c,stroke-width:2px,color:#111\n    classDef risk fill:#FFE8E8,stroke:#e65100,stroke-width:2px,stroke-dasharray: 6 4,color:#111\n",
