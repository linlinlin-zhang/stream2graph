    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对的，注册流程走DiagnosticEngine，登录流程走PatientRecords。另外我想把开始部分单独框起来，叫Inicio del App。",
      "elements_involved": [
