  "diagram_type": "stateDiagram",
  "code": "%%{init: {'theme': 'default', 'themeVariables': { 'primaryColor': '#f5f5f5', 'primaryTextColor': '#333333', 'primaryBorderColor': '#cccccc', 'lineColor': '#666666', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#ffffff' }}}%%\nstateDiagram-v2\n    [*] --> Created: Create Todo\n    Created --> InProgress: Start Work\n    Created --> Cancelled: Cancel\n    InProgress --> OnHold: Pause\n    InProgress --> Completed: Complete\n    InProgress --> Cancelled: Cancel\n    OnHold --> InProgress: Resume\n    OnHold --> Cancelled: Cancel\n    Completed --> [*]\n    Cancelled --> [*]\n\n    state Created {\n        [*] --> Draft\n        Draft --> ReadyToStart: Finalize\n        ReadyToStart --> [*]\n    }\n\n    state InProgress {\n        [*] --> Started\n        Started --> InReview: Submit for Review\n        InReview --> Started: Request Changes\n        InReview --> [*]: Approve\n    }\n\n    state OnHold {\n        [*] --> Blocked\n        [*] --> Deferred\n        Blocked --> [*]: Unblock\n        Deferred --> [*]: Prioritize\n    }\n\n    state Completed {\n        [*] --> Done\n        [*] --> PartiallyDone\n        Done --> [*]\n        PartiallyDone --> [*]\n    }",
