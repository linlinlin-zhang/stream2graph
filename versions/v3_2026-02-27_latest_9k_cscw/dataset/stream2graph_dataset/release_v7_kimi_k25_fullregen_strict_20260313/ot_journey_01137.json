  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想画一个用户旅程图，记录我典型的工作日。整体分成两大块：早上出门上班，以及晚上下班回家。",
      "elements_involved": [
