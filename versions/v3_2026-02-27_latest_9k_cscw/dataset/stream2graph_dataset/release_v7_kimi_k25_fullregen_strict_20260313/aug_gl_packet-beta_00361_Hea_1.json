  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为HealthTech的实验室分析系统画一个完整的连接流程图。核心场景是诊断引擎和患者记录系统之间的数据流转，要体现HIPAA合规和EMR同步这两个关键点。",
      "elements_involved": [
