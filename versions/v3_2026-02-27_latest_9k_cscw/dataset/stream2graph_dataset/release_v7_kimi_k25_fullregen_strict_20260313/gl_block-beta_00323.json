    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为Macro Browser画一个系统上下文图，核心是展示这个隐私导向的Web3浏览器如何与外部系统交互。先确定中心节点吧。",
      "elements_involved": [
