        "parsing"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "parsing完成后自动进入extracting状态提取关键字段，这个AUTO转换还是由Broker侧触发。提取完再进入tracing做执行轨迹追踪。",
      "elements_involved": [
        "parsing",
        "extracting",
