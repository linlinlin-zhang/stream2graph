  "code": "graph TD\n    %% OJS Complete Workflow with Autonomous Agents\n    \n    %% Author Journey\n    A1[Retail_CustomerLoyalty] --> A2[Retail_Inventory]\n    A2 --> A3[Retail_OrderManagement]\n    A3 --> A4[Retail_CustomerLoyalty]\n    A4 --> A5[Retail_Inventory]\n    \n    %% Autonomous Agents for Authors\n    RA[Retail_Inventory] -.-> A1\n    WA[Retail_CouponSystem] -.-> A1\n    JMA[Retail_Inventory] -.-> A2\n    FA[Retail_CouponSystem] -.-> A2\n    SA[Retail_CustomerLoyalty] -.-> A3\n    RAA[Retail_OrderManagement] -.-> A4\n    PA[Retail_PointOfSale] -.-> A5\n    \n    %% Editorial Journey\n    E1[Retail_Inventory] --> E2[Retail_Inventory]\n    E2 --> E3[Retail_PointOfSale]\n    E3 --> E4[Retail_Inventory]\n    E4 --> E5[Retail_CouponSystem]\n    \n    %% Autonomous Agents for Editors\n    TA[Retail_CustomerLoyalty] -.-> E1\n    RMA[Retail_OrderManagement] -.-> E2\n    MA[Retail_OrderManagement] -.-> E3\n    DSA[Retail_CouponSystem] -.-> E4\n    HA[Retail_PointOfSale] -.-> E5\n    \n    %% Reviewer Journey\n    R1[Retail_PointOfSale] --> R2[Retail_PointOfSale]\n    R2 --> R3[Retail_OrderManagement]\n    \n    %% Autonomous Agents for Reviewers\n    IAA[Retail_OrderManagement] -.-> R1\n    AA[Retail_CustomerLoyalty] -.-> R2\n    QA[Retail_PointOfSale] -.-> R2\n    SUA[Retail_PointOfSale] -.-> R3\n    \n    %% Journal Manager Journey\n    J1[Retail_CouponSystem] --> J2[Retail_CustomerLoyalty]\n    J2 --> J3[Retail_OrderManagement]\n    \n    %% Autonomous Agents for Managers\n    ANA[Retail_PointOfSale] -.-> J1\n    QMA[Retail_OrderManagement] -.-> J2\n    POA[Retail_CustomerLoyalty] -.-> J3\n    \n    %% Workflow Stages\n    WS1[Retail_CustomerLoyalty] --> WS2[Retail_OrderManagement]\n    WS2 --> WS3[Retail_CouponSystem]\n    WS3 --> WS4[Retail_CustomerLoyalty]\n    WS4 --> WS5[Retail_Inventory]\n    \n    %% Connections between journeys and stages\n    A3 --> WS1\n    E1 --> WS1\n    E2 --> WS2\n    E2 --> WS3\n    R1 --> WS3\n    E4 --> WS4\n    E5 --> WS5