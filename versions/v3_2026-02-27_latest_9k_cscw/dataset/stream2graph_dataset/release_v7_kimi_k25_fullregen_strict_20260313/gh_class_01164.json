  "code": "classDiagram\n    class FilterNode {\n        <<abstract>>\n    }\n\n    class PropertyFilter {\n        string Operator\n        string Property\n        string? Value\n        bool IgnoreCase\n    }\n\n    class CompositeFilter {\n        string Operator\n        List<FilterNode> Children\n    }\n\n    class QueryFilter~T~ {\n        Expression<Func<T,bool>> Predicate\n    }\n\n    FilterNode <|-- PropertyFilter\n    FilterNode <|-- CompositeFilter\n    QueryFilter~T~ --> FilterNode : \"rehydrated from\"\n",
