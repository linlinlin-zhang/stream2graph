  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个SQL查询在SQLite内部的完整执行流程。从解析开始，一直到返回结果。我想用TD布局，从上到下展示整个管道。",
      "elements_involved": [
