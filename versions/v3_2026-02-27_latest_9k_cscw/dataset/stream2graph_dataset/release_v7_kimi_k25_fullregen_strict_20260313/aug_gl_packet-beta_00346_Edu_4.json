  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个TCP包结构图，用于教育场景的技术培训。重点是让学生理解头部字段和实际承载的数据怎么对应到具体的教育服务。",
      "elements_involved": [
        "TCP Packet",
        "Source Port",
        "Destination Port",
        "Sequence Number",
