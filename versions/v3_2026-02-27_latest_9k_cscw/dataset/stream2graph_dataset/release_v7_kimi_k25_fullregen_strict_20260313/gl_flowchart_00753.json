  "code": "flowchart TD\n    START([Inicio]) --> REGISTER_EMPRESA[Registrar Empresa<br/>sin RFC = PRE-REGISTRO]\n    REGISTER_EMPRESA --> ADD_RFC{¿Tiene RFC?}\n    \n    ADD_RFC -->|No| PRE_REGISTRO[Estado:<br/>PRE-REGISTRO]\n    ADD_RFC -->|Sí| VALIDATE_RFC[Validar RFC]\n    \n    VALIDATE_RFC --> PROSPECTO[Estado:<br/>PROSPECTO]\n    \n    PRE_REGISTRO --> WAIT_RFC[Esperar RFC]\n    WAIT_RFC --> VALIDATE_RFC\n    \n    PROSPECTO --> CREATE_CONTACT[Crear Contacto]\n    CREATE_CONTACT --> LINK_CONTACT[Vincular Contacto<br/>con Empresa]\n    \n    LINK_CONTACT --> REQUEST_ASSIGN[Vendedor Solicita<br/>Asignación]\n    REQUEST_ASSIGN --> MANAGER_REVIEW{Gerente<br/>Revisa}\n    \n    MANAGER_REVIEW -->|Rechaza| NOTIFY_REJECT[Notificar<br/>Rechazo]\n    MANAGER_REVIEW -->|Aprueba| ASSIGN_APPROVED[Asignación<br/>Aprobada]\n    \n    NOTIFY_REJECT --> END1([Fin])\n    \n    ASSIGN_APPROVED --> FIRST_VISIT[Primera Visita/<br/>Llamada]\n    FIRST_VISIT --> FOLLOW_UP[Seguimientos<br/>Periódicos]\n    \n    FOLLOW_UP --> INTERESTED{¿Cliente<br/>Interesado?}\n    \n    INTERESTED -->|No| MARK_INACTIVE[Marcar como<br/>No Interesado]\n    INTERESTED -->|Sí| CREATE_QUOTE[Crear<br/>Cotización]\n    \n    MARK_INACTIVE --> END2([Fin])\n    \n    CREATE_QUOTE --> ADD_ITEMS[Agregar Items<br/>a Cotización]\n    ADD_ITEMS --> CALC_TOTALS[Calcular<br/>Totales]\n    CALC_TOTALS --> SEND_QUOTE[Enviar<br/>Cotización]\n    \n    SEND_QUOTE --> FOLLOW_QUOTE[Seguimiento de<br/>Cotización]\n    FOLLOW_QUOTE --> QUOTE_RESULT{Resultado}\n    \n    QUOTE_RESULT -->|Rechazada| END3([Fin])\n    QUOTE_RESULT -->|Aceptada| CREATE_SALE[Crear Venta]\n    \n    CREATE_SALE --> CLIENTE[Estado:<br/>CLIENTE]\n    CLIENTE --> CREATE_BILLING[Crear Registro<br/>de Cobranza]\n    \n    CREATE_BILLING --> WAIT_PAYMENT[Esperar<br/>Pago]\n    WAIT_PAYMENT --> PAYMENT{Tipo de<br/>Pago}\n    \n    PAYMENT -->|Parcial| PARTIAL_PAY[Registrar<br/>Pago Parcial]\n    PAYMENT -->|Total| FULL_PAY[Registrar<br/>Pago Total]\n    \n    PARTIAL_PAY --> WAIT_PAYMENT\n    FULL_PAY --> PAID[Cobranza<br/>Pagada]\n    \n    PAID --> CALC_COMMISSION[Calcular<br/>Comisiones]\n    CALC_COMMISSION --> NOTIFY_COMMISSION[Notificar<br/>Comisiones]\n    \n    NOTIFY_COMMISSION --> END4([Fin])\n\n    style START fill:#e8f5e9\n    style PRE_REGISTRO fill:#fff3e0\n    style PROSPECTO fill:#e3f2fd\n    style CLIENTE fill:#c8e6c9\n    style CREATE_SALE fill:#a5d6a7\n    style PAID fill:#81c784\n    style END1 fill:#ffcdd2\n    style END2 fill:#ffcdd2\n    style END3 fill:#ffcdd2\n    style END4 fill:#e8f5e9\n",
