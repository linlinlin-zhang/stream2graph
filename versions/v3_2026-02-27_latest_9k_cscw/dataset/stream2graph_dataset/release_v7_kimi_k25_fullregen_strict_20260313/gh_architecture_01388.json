    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "需要区分。main分支用\"on main\"，release用\"on GitHub release\"，PR用\"on PR\"。这三条线都要清晰标注触发条件。",
      "elements_involved": [
        "DocumentationBuilder",
        "main",
        "GitHub release",
        "PR"
