    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个事件生命周期的时间线图，展示零售系统中优惠券和库存模块的创建与更新流程。核心节点是四个阶段：Created、Updated、System Created、System Updated。",
