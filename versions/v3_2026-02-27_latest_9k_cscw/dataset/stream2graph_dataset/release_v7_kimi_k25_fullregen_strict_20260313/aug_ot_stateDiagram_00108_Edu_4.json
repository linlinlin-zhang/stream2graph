  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为教育LMS门户设计一个任务状态流转图，核心是从创建到完成的完整生命周期。起点应该是ClassroomService触发创建动作。",
      "elements_involved": [
        "Education_ClassroomService",
        "Created",
        "Create Todo"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，起点是ClassroomService。那创建之后，任务进入什么状态？是直接进入进行中，还是先有个草稿阶段？",
      "elements_involved": [
        "Created",
        "Draft"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Created状态内部需要细分：先有Draft草稿态，教师可以编辑内容，确认无误后Finalize进入ReadyToStart。这两个子状态都封装在Created复合状态里。",
      "elements_involved": [
        "Created",
        "Draft",
        "ReadyToStart",
        "Finalize"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，Created复合状态包含Draft和ReadyToStart，Finalize触发流转。那从Created出去的主路径呢？",
      "elements_involved": [
        "Created",
        "InProgress",
        "Start Work"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "主路径是Start Work进入InProgress，但要有Cancel分支。另外InProgress本身也是个复合状态，需要GradeSync介入。",
      "elements_involved": [
        "Created",
        "InProgress",
        "Start Work",
        "Cancelled",
        "Education_GradeSync"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "InProgress内部怎么设计？GradeSync是起点还是参与某个子状态？",
      "elements_involved": [
        "InProgress",
        "Education_GradeSync",
        "Started",
        "InReview"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "InProgress里，GradeSync指向Started作为入口。然后Started可以Submit for Review到InReview，InReview有两个出口：Request Changes回Started，或者Approve直接回到ClassroomService完成。",
      "elements_involved": [
        "InProgress",
        "Education_GradeSync",
        "Started",
        "InReview",
        "Submit for Review",
        "Request Changes",
        "Approve",
        "Education_ClassroomService"
      ],
      "is_repair": false
    },
    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已绘制InProgress复合状态。我发现InProgress还有Pause动作，是不是要引出OnHold状态？",
      "elements_involved": [
        "InProgress",
        "OnHold",
        "Pause"
      ],
      "is_repair": false
    },
    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，OnHold是暂停态，内部关联StudentDB。要有Blocked和Deferred两个子状态，Blocked可以Unblock回到StudentDB，Deferred则可以Prioritize跳转到GradeSync重新激活。",
      "elements_involved": [
        "OnHold",
        "Education_StudentDB",
        "Blocked",
        "Deferred",
        "Unblock",
        "Prioritize",
        "Education_GradeSync"
