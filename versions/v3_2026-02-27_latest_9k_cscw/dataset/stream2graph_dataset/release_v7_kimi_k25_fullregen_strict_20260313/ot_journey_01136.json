  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要做一个客户旅程图，重点展示从发现网站到完成支付的完整流程。我想分成两个阶段：Discovery 和 Purchase。",
      "elements_involved": [
        "Discovery",
