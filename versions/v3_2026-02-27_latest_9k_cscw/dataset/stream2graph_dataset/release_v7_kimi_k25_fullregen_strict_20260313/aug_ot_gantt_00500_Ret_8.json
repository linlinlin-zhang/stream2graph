    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Standard阶段要紧跟在Intro Offer后面，持续3个月；然后Full Price再跟Standard，持续12个月。命名上Standard和Full Price都要标注清楚属于Retail_OrderManagement。",
      "elements_involved": [
        "Standard",
        "Full Price",
