    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为教育场景设计一个自动化工作流，核心是Education_ClassroomService作为中枢，处理来自Education_StudentDB的学生数据推送。",
      "elements_involved": [
