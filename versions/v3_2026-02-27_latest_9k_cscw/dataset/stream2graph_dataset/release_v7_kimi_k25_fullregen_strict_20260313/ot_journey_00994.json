    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "下午先吃午饭，2分。然后继续工作，这个叫More work吧，也是1分，同样Me和Cat一起。",
      "elements_involved": [
        "Afternoon",
