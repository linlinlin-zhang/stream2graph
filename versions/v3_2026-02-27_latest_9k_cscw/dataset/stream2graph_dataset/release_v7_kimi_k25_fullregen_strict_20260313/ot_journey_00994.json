    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想画一个用户旅程图，记录我典型的工作日。整体标题就叫\"My working day\"吧，分成上午和下午两个大段。",
      "elements_involved": [
