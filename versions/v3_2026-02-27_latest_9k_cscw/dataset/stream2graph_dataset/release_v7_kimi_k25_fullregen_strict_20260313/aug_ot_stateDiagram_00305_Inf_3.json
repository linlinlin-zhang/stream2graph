      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "需要，任务完成后Moving应该能回到Still。另外还有一个关键分支：Moving如果发生严重故障，要进入Crash状态。",
      "elements_involved": [
        "Moving",
