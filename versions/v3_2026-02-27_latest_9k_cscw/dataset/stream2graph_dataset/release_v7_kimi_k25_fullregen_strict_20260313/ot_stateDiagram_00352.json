  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个文档生命周期的状态图，从创建到最终归档的完整流程。起点应该是初始状态，然后进入Draft状态。",
      "elements_involved": [
        "[*]",
        "Draft"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，起点到Draft。那Draft之后有哪些去向？是直接进入审批，还是有其他分支？",
      "elements_involved": [
        "Draft"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Draft可以提交到Review进行审批，也可以直接删除进入Archived。审批环节是关键，Review之后可能approve通过，也可能reject驳回，或者退回Draft要求修改。",
      "elements_involved": [
        "Draft",
        "Review",
        "Archived",
        "Approved",
        "Rejected"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我先把主线画出来：Draft→Review（submit），Draft→Archived（delete），以及Review的三个出口到Approved、Rejected和回退到Draft。",
      "elements_involved": [
        "Draft",
        "Review",
        "Archived",
        "Approved",
        "Rejected",
        "submit",
        "delete",
        "approve",
        "reject",
        "request_changes"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Rejected之后应该能revise修订回到Draft，Approved之后publish发布到Published状态。Published最终也可以archive归档。",
      "elements_involved": [
        "Rejected",
        "Draft",
        "Approved",
        "Published",
        "Archived",
        "revise",
        "publish",
        "archive"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认一下：Rejected→Draft（revise），Approved→Published（publish），Published→Archived（archive）。那Archived是终点吗？",
      "elements_involved": [
        "Rejected",
        "Draft",
        "Approved",
        "Published",
        "Archived",
        "revise",
        "publish",
        "archive",
