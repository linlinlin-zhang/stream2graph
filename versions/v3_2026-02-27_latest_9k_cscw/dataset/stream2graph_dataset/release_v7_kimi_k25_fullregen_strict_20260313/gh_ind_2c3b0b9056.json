  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想画一个用户旅程图，记录我典型的工作日流程。整体分成两大块：上班和回家。",
      "elements_involved": [
        "journey",
        "section Go to work",
