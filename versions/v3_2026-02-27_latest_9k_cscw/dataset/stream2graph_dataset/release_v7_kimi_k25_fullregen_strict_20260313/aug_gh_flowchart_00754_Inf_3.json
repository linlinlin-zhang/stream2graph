      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "对的，E是LoadBalancer，目前只从Etcd读取后端节点配置。需要它连IngressController吗？",
      "elements_involved": [
        "Infra_LoadBalancer",
        "Infra_EtcdCluster",
