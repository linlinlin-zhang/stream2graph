      "action_type": "confirm",
      "utterance": "确认一下结构：NeedMore自循环标注more input；NeedMore到Complete的触发条件是EOF或complete；NeedMore到Error是error触发。这样三条出边对吗？",
      "elements_involved": [
        "NeedMore",
        "Complete",
        "Error",
        "EOF/complete",
