  "code": "%%{init: {'theme': 'default', 'themeVariables': { 'primaryColor': '#f5f5f5', 'primaryTextColor': '#333333', 'primaryBorderColor': '#cccccc', 'lineColor': '#666666', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#ffffff' }}}%%\nclassDiagram\n    class Query {\n        +validate()\n        +rules()\n    }\n    \n    class QueryHandler {\n        +handle(Query query)\n    }\n    \n    class ReadModel {\n        +id\n        +attributes\n        +find()\n        +findAll()\n    }\n    \n    class QueryResult {\n        +data\n        +meta\n    }\n    \n    Query --> QueryHandler: processed by\n    QueryHandler --> ReadModel: retrieves from\n    ReadModel --> QueryResult: transformed to",
