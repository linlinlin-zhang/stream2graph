  "diagram_type": "flowchart",
  "code": "flowchart TD\n  %% Styling\n  classDef user fill:#E3F2FD,stroke:#90CAF9;\n  classDef assistant fill:#E8F5E9,stroke:#A5D6A7;\n  classDef decision fill:#FFF8E1,stroke:#FFD54F;\n  classDef app fill:#F3E5F5,stroke:#CE93D8;\n  classDef tool fill:#FBE9E7,stroke:#FFAB91;\n\n  %% User interaction\n  U[FinTech_LedgerService] --> A1[FinTech_TransactionQueue]\n\n  %% Assistant context\n  H1[FinTech_AuthVault] --> A1\n  A1 --> T1[FinTech_TransactionQueue] --> A1\n\n  %% Ambiguity check\n  A1 --> D1{FinTech_LedgerService}\n  D1 -- Yes --> C1[FinTech_LedgerService] --> U\n  D1 -- No --> A2[FinTech_PaymentGateway]\n\n  %% Additional data check\n  A2 --> D2{FinTech_TransactionQueue}\n  D2 -- Yes --> R1[FinTech_LedgerService] --> APPD[FinTech_TransactionQueue]\n  D2 -- No --> AT\n\n  %% App execution\n  APPD --> AT[FinTech_AuthVault]\n\n  %% Finalization paths\n  AT -- Needs App Execution --> APP_ACK[FinTech_FraudDetection] --> U2[FinTech_LedgerService]\n  AT -- No Execution Needed --> U2\n\n  %% Class tags\n  class U,U2 user\n  class A1,A2,C1,R1,R2,CALL,AT assistant\n  class D1,D2 decision\n  class APPD,APP_ACK app\n  class T1,H1 tool\n",
