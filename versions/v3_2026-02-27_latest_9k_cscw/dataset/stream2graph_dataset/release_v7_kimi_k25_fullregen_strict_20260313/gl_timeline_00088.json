  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想画一个科学哲学的时间线，展示库恩的范式理论。核心是从常规科学到危机再到新范式的循环。需要三个主要阶段。",
      "elements_involved": [
        "Paradigma",
