  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为电子健康档案系统设计一个用户旅程图，展示从打开文件到创建新文件的完整工作流。整体标题就叫\"文件管理工作流\"吧。",
      "elements_involved": [
