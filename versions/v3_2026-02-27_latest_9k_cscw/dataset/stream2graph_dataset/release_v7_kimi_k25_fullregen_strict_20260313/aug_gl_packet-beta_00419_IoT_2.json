  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为工业物联网PLC场景设计一个TCP报文格式说明图。核心是要把标准TCP头部和自定义的工业逻辑字段结合起来，特别是要在Options位置嵌入我们的IoT_Industrial_PLC_Logic字段。",
      "elements_involved": [
        "Source Port",
        "Destination Port",
        "IoT_Industrial_PLC_Logic"
