    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Stream返回的是DenseInstance类型，要标注清楚。然后PE拿着这个inst去问Classifier要votes，调用get_votes_for_instance。",
      "elements_involved": [
        "Stream",
        "DenseInstance",
        "inst",
        "Classifier",
        "votes",
        "get_votes_for_instance"
