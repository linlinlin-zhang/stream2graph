    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个预评估流程的时序图，核心是PrequentialEvaluator怎么一边从Stream取数据，一边让Classifier做预测和训练。",
      "elements_involved": [
        "PrequentialEvaluator",
        "Stream",
        "Classifier"
