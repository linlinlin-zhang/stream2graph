  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个购物车状态流转图，核心状态包括：空购物车、活跃状态、结账中、已完成和废弃。起点是空购物车，终点有两个分支。",
      "elements_involved": [
        "Empty",
        "Active",
        "InCheckout",
        "CheckedOut",
        "Abandoned",
        "[*]"
