        "DRAFT",
        "SubmittedForReview"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "提交后进入REVIEW评审态。这里要体现Guard审查机制，用的是DockerImage做安全扫描。审查员可以要求修改或者直接拒绝。",
      "elements_involved": [
        "REVIEW",
        "CloudNative_DockerImage",
        "ChangesRequested",
        "RejectedAtReview"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "REVIEW有两个出口：回DRAFT修改，或者到REJECTED终止。那通过评审后呢？",
      "elements_involved": [
        "REVIEW",
        "DRAFT",
        "REJECTED"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "通过评审后进入OPEN_FOR_VOTE投票态，这个状态转换要标记为ApprovedForVoting，由K8sCluster调度投票窗口。",
      "elements_involved": [
