rusionDetection]\r\n        VP[Security_Encryption]\r\n        MCE[Security_Encryption]\r\n        MM[Security_IntrusionDetection]\r\n        TAI[Security_OAuth2]\r\n        FLI[Security_OAuth2]\r\n    end\r\n    class IP,VP,MCE,MM,TAI,FLI media;\r\n\r\n    subgraph \"Memory & Context\"\r\n        MMGR[Security_ZeroTrust]\r\n        MHMGR[Security_OAuth2]\r\n        CMGR[Security_Firewall]\r\n        KGR[Security_ZeroTrust]\r\n    end\r\n    class MMGR,MHMGR,CMGR,KGR memory;\r\n\r\n    subgraph \"Group Collaboration\"\r\n        GCI[Security_Firewall]\r\n        GCM[Security_Encryption]\r\n        GSA[Security_Firewall]\r\n    end\r\n    class GCI,GCM,GSA group;\r\n\r\n    subgraph \"Document & Export\"\r\n        DP[Security_Encryption]\r\n        SDE[Security_Firewall]\r\n        AIDG[Security_Encryption]\r\n    end\r\n    class DP,SDE,AIDG doc;\r\n\r\n    subgraph \"Database & Storage\"\r\n        DB[Security_Firewall]\r\n        CACHES[Security_ZeroTrust]\r\n    end\r\n    class DB,CACHES db;\r\n\r\n    subgraph \"Infrastructure\"\r\n        DOCKER[Security_ZeroTrust]\r\n        DCOMPOSE[Security_Firewall]\r\n        ENV[Security_ZeroTrust]\r\n        PROC[Security_IntrusionDetection]\r\n    end\r\n    class DOCKER,DCOMPOSE,ENV,PROC infra;\r\n\r\n    %% Connections\r\n    TG --> FA\r\n    WA --> FA\r\n    FA --> MW\r\n    MW --> RT\r\n    RT --> CH\r\n    CH --> BCH\r\n    CH --> IMCH\r\n    CH --> MDCH\r\n    CH --> DOCH\r\n    CH --> EXCH\r\n    CH --> CBH\r\n    CH --> OWAC\r\n\r\n    CH --> MC\r\n    CH --> MH\r\n    MH --> ORA\r\n    MH --> GA\r\n    MH --> DSA\r\n    MH --> SSM\r\n\r\n    CH --> IP\r\n    CH --> VP\r\n    CH --> MCE\r\n    CH --> MM\r\n    IMCH --> TAI\r\n    IMCH --> FLI\r\n\r\n    CH --> MMGR\r\n    CH --> MHMGR\r\n    CH --> CMGR\r\n    CH --> KGR\r\n\r\n    CH --> GCI\r\n    GCI --> GCM\r\n    GCI --> GSA\r\n\r\n    CH --> DP\r\n    DP --> SDE\r\n    DP --> AIDG\r\n\r\n    CH --> DB\r\n    CH --> CACHES\r\n    MMGR --> DB\r\n    KGR --