    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "好的，我理解是要用sequenceDiagram来画。Client和Server作为两个participant，是这样吗？Client在左，Server在右？",
      "elements_involved": [
        "Client",
        "Server"
