  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为技术白皮书做一个应用场景的思维导图，中心主题是各种Applications。我想按芯片类型来组织，分成车载SoC、IoT/产业、数字SoC，还有AMS混载这几大类。",
      "elements_involved": [
        "Applications",
        "車載SoC",
        "IoT/産業",
        "デジタルSoC",
        "AMS混載"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白了，用mindmap形式。那每类应用下面的关键特性您希望怎么展开？比如车载SoC这边，除了高温高可靠性，还有别的重点吗？",
      "elements_involved": [
        "車載SoC",
        "高温・高信頼"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "车载这块再加一个低噪声和EMI抑制吧，这是车规级电源很重要的指标。IoT和工业应用的话，突出小型化低功耗，还有RF灵敏度要保持。",
      "elements_involved": [
        "車載SoC",
        "低ノイズ/EMI",
        "IoT/産業",
        "小型・低消費",
        "RF感度維持"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，车载SoC下面放高温高可靠性和低噪声/EMI，IoT产业下面放小型低功耗和RF感度维持。数字SoC和AMS混载这边您打算怎么细化？",
      "elements_involved": [
        "デジタルSoC",
        "AMS混載"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "数字SoC重点讲DVFS动态调压和瞬态响应性能。AMS混载的话，强调高PSRR电源抑制比和高精度模拟，这是模拟数字混合设计的核心诉求。",
      "elements_involved": [
        "デジタルSoC",
        "DVFS",
        "過渡応答",
        "AMS混載",
        "高PSRR",
        "高精度アナログ"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "结构都整理好了，我画出来您看看：中心是Applications，四个分支——车载SoC带高温高可靠和低噪声EMI；IoT产业带小型低功耗和RF感度；数字SoC带DVFS和瞬态响应；AMS混载带高PSRR和高精度模拟。",
      "elements_involved": [
        "Applications",
        "車載SoC",
        "IoT/産業",
        "デジタルSoC",
        "AMS混載"
      ],
      "is_repair": false
