      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认：主链路是EdgeNode → TelemetryStream → ActuatorController → PLC_Logic，然后进入子图循环。PLC_Logic在循环内又连到另一个TelemetryStream。",
      "elements_involved": [
        "IoT_Industrial_EdgeNode",
        "IoT_Industrial_TelemetryStream",
        "IoT_Industrial_ActuatorController",
        "IoT_Industrial_PLC_Logic"
