      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "EMR_Sync完成后，数据要回写给DiagnosticEngine，形成闭环。这是最后一步。",
      "elements_involved": [
        "HealthTech_EMR_Sync",
        "HealthTech_DiagnosticEngine"
