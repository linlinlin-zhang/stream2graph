  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个混合控制回路的流程图，针对工业炉窑的温度控制。核心思想是把物理模型和数据驱动模型结合起来。",
      "elements_involved": [
        "Control",
        "Furnace Hybrid Control Loop"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，这是一个闭环控制系统。起点应该是传感器采集数据吧？需要包含哪些测量量？",
      "elements_involved": [
        "Sensors"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，传感器节点要标注清楚：炉膛出口温度T_out、入口温度T_in、燃料体积流量F_vol，还有空燃比AFR这些关键参数。",
      "elements_involved": [
        "Sensors",
        "T_out",
        "T_in",
        "F_vol",
        "AFR"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好，我先把Sensors节点画出来，标注为\"Sensors (T_out, T_in, F_vol, AFR, etc.)\"。接下来数据流向哪里？",
      "elements_involved": [
        "Sensors"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "传感器数据先进入特征提取模块。这里我们还在评估用Attention机制还是CNN，所以先写TBD。",
      "elements_involved": [
        "FE",
        "Feature Extraction",
        "Attention",
        "CNN"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "收到，Feature Extraction用梯形表示，标注Attention/CNN – TBD。这个模块之后分成两路吗？",
      "elements_involved": [
        "FE",
        "Feature Extraction"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "是的，双分支结构。一路走PINN，基于第一性原理的物理模型；另一路走LNN，在线学习器，负责补偿未建模动态。",
      "elements_involved": [
        "PINN",
        "LNN",
        "First-Principles Model",
        "On-the-Fly Learner"
      ],
      "is_repair": false
    },
    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加PINN和LNN两个并行节点。PINN标注First-Principles Model，LNN标注On-the-Fly Learner。PINN这边后续怎么连接？",
      "elements_involved": [
        "PINN",
        "LNN"
      ],
      "is_repair": false
    },
    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "PINN输出到PhysCalc，计算理论温度T_phys。然后和实测温度T_meas做比较，得到误差e。",
      "elements_involved": [
        "PhysCalc",
        "T_phys",
        "Error",
        "T_meas",
