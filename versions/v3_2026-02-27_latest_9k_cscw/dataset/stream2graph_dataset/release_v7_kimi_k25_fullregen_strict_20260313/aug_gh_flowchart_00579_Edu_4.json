    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为教育系统设计一个LMS门户的数据流图。核心是学生数据库和成绩同步模块之间的交互。",
      "elements_involved": [
        "Education_LMS_Portal",
