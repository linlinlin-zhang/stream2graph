      "role": "Domain_Expert",
      "action_type": "clarify",
      "utterance": "是循环同步的意思——成绩同步服务需要自我校验，同时把数据推送到LMS门户。",
      "elements_involved": [
        "Education_GradeSync",
        "Education_LMS_Portal"
