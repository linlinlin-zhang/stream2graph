    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "需要校验。边缘节点输出原始数据值RAWVAL，这里要分两支：PASS的走正常处理流程，FAIL的直接触发停止机制。",
      "elements_involved": [
