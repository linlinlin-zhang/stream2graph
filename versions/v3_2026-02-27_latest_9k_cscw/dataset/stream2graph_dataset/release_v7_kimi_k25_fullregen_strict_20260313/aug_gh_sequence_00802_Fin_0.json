    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Alice发起交易邀请的时序图。Alice作为外部参与者，她要先向offer-up.contract发起一个makeTradeInvitation调用，目标是FinTech_PaymentGateway。",
      "elements_involved": [
