      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Zoe用虚线箭头异步返回一个invitation对象给合约，同时deactivate Zoe。然后合约要activate，把Invitation toJoin发给Alice。",
      "elements_involved": [
        "Zoe",
