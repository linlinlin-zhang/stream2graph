    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "用Postman。流程要清晰：第一步Postman向Cognito发认证请求，第二步Cognito返回JWT令牌，第三步Postman带令牌调APIGW，第四步APIGW返回响应。",
      "elements_involved": [
        "Postman",
