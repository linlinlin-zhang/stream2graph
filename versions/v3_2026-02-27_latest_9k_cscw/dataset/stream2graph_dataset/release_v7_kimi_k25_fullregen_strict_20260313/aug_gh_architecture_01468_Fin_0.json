  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为FinTech系统画一张AWS架构图，核心是用Cognito做认证，API Gateway做入口，Lambda处理业务逻辑。",
      "elements_involved": [
