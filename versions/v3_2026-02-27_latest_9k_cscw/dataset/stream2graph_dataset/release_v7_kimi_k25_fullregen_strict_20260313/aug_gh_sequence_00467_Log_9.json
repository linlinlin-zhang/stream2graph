      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，A到S画一条ARP Request消息，标注源是A(Warehouse)，目标是Broadcast(DeliveryRoute)。",
      "elements_involved": [
        "A-S",
        "ARP Request",
        "Logistics_Warehouse",
