    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个物流网络中的ARP协议交互时序图，场景是四台电脑通过交换机通信，每台电脑都关联一个物流业务标签。",
      "elements_involved": [
