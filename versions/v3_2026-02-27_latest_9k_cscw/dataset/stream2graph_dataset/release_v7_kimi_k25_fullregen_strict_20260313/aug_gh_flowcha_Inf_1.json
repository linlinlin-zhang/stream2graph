  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一张基础设施的流量图，核心是展示从入口到负载均衡器，再到集群、缓存，最后到工作节点的完整链路。",
      "elements_involved": [
        "Infra_Ingress",
