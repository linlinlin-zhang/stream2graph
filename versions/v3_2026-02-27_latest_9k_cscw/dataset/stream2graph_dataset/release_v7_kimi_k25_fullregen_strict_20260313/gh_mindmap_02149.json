  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要做一个关于财务素养的思维导图，核心是Financial Literacy，作为根节点。我想先规划五个主要分支，覆盖生活方式、风险、收入类型、指导原则和维度这五个层面。",
      "elements_involved": [
        "Financial Literacy",
        "Lifestyles",
        "Risks",
        "Income Types",
        "Guiding Principles",
        "Dimensions"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "明白，五个一级分支都记下了。先从Lifestyles开始吧，这个节点下面需要展开哪些具体内容？",
      "elements_involved": [
        "Lifestyles"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "生活方式下面放三种状态：Live above your means、Live at your means、Live below your means，分别对应入不敷出、收支平衡和量入为出。",
      "elements_involved": [
        "Live above your means",
        "Live at your means",
        "Live below your means"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，Lifestyles分支已添加。接下来是Risks风险部分，您打算包含哪些风险类型？",
      "elements_involved": [
        "Risks"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "风险这块要有Inflation通货膨胀、Market Risk市场风险——后面可以标注一下Volatility波动性、Tax税务风险，还有Health健康风险。",
      "elements_involved": [
        "Inflation",
        "Market Risk",
        "Volatility",
        "Tax",
        "Health"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "Market Risk和Volatility的关系我确认一下，是把Volatility作为Market Risk的别名标注，还是并列的两个节点？",
      "elements_involved": [
        "Market Risk",
        "Volatility"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "用竖线标注，Market Risk | Volatility，表示市场风险的同义或核心特征。",
      "elements_involved": [
        "Market Risk",
        "Volatility"
      ],
      "is_repair": false
    },
    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "Risks分支完成了。Income Types收入类型这边怎么设计？",
      "elements_involved": [
        "Income Types"
      ],
      "is_repair": false
    },
    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "收入类型分两大维度：按性质分Active主动收入和Passive被动收入；按结构分Single Stream单一收入来源和Multi Stream多元收入来源。四个节点并列放在Income Types下面。",
      "elements_involved": [
        "Active",
        "Passive",
        "Single Stream",
        "Multi Stream"
      ],
      "is_repair": false
    },
    {
      "turn_id": 10,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加。Guiding Principles指导原则这个分支看起来需要更深的层级？",
      "elements_involved": [
        "Guiding Principles"
      ],
      "is_repair": false
    },
    {
      "turn_id": 11,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，这里有两个核心概念。Net Worth净资产下面展开Assets资产和Liabilities负债；Income收入下面展开Revenue收益和Expenses支出。",
      "elements_involved": [
        "Net Worth",
        "Assets",
