      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "样式方案：SDP核心组件用浅蓝底，BYOD用橙色表示外部风险，AVD用绿色表示安全客户端，资源和服务用紫色系区分。",
      "elements_involved": [
        "CTRL",
        "GW1",
        "GW2",
        "BYOD",
        "AVD",
        "DOMAIN",
        "DEV",
        "SEG",
        "DOMSVC",
        "DEVSVC",
        "HWIL"
