        "Audit"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "repair",
      "utterance": "收到，我调整一下方向——让TransactionQueue指向FraudDetection，同时加上Risk到Signal，以及Signal到队列的链路。这样风控信号能实时反馈给队列。",
      "elements_involved": [
