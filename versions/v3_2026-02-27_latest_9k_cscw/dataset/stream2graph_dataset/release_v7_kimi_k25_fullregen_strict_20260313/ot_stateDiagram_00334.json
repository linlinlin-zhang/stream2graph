    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "每道题分两个阶段：准备阶段和展示阶段。主持人初始化题目后进入准备状态，然后主动展示题目，进入答题激活状态。",
      "elements_involved": [
        "QuestionPrep",
        "QuestionActive",
        "Init Question",
        "Host Shows"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我加上了 GameStarted 到 QuestionPrep 的流转，标注为 Init Question，还有 QuestionPrep 到 QuestionActive，标注 Host Shows。玩家怎么参与？",
      "elements_involved": [
        "GameStarted",
        "QuestionPrep",
        "QuestionActive",
        "Init Question",
        "Host Shows"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "玩家抢答，进入答案校验状态。答对了就回到准备下一题，答错了返回当前题目继续抢答。",
      "elements_involved": [
        "AnswerValidation",
        "Player Buzzes",
        "Correct Answer",
        "Wrong Answer",
        "QuestionPrep",
        "QuestionActive"
      ],
      "is_repair": false
    },
    {
