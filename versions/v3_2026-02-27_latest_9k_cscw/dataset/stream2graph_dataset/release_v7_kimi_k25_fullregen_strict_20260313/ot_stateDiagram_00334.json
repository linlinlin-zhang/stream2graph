      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认一下：AnswerValidation 有两个出口，Correct Answer 回到 QuestionPrep 准备下一题，Wrong Answer 回到 QuestionActive 继续当前题目。对吗？",
      "elements_involved": [
        "AnswerValidation",
        "Correct Answer",
        "Wrong Answer",
        "QuestionPrep",
        "QuestionActive"
      ],
      "is_repair": false
