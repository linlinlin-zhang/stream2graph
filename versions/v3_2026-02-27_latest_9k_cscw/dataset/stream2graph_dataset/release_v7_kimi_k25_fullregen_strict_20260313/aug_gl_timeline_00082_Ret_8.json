    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个支付流程的时间线图，展示从用户提交表单到最终确认的全过程。核心是Retail_CustomerLoyalty这个系统的支付链路。",
      "elements_involved": [
        "Retail_CustomerLoyalty",
        "timeline"
