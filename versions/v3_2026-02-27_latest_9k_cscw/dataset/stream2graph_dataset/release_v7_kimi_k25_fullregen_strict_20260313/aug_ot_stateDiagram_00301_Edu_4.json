      "role": "Domain_Expert",
      "action_type": "clarify",
      "utterance": "Loading到Success的触发条件应该是Data Received，Error那边是Request Failed，这个要标注清楚。",
      "elements_involved": [
        "Loading",
        "Success",
        "Error"
