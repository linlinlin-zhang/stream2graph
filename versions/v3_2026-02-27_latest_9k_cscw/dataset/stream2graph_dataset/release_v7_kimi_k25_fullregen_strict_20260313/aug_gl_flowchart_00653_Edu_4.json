    {
      "turn_id": 11,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "如果CheckResponse为Yes，进入CompareAnswer，也是GradeSync服务，用来比对答案正确性；如果为No，直接回到OtherFamilyChance，让其他家庭有机会。",
      "elements_involved": [
