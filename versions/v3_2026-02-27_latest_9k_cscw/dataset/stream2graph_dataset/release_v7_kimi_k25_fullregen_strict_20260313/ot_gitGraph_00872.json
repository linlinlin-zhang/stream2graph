  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Git流程图，展示主干和两条特性分支的并行开发。主干main上先有初始提交a，然后分出feature_1和feature_2两条分支，最后合并回来。",
      "elements_involved": [
        "main",
        "feature_1",
        "feature_2",
        "commit a"
