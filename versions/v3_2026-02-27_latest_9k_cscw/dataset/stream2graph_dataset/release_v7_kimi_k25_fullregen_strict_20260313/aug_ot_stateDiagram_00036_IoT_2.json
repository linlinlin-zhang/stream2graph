  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个工业IoT执行器控制的状态流转图。核心设备有三个：ActuatorController、MQTT Broker和EdgeNode。状态主要是静止和运动两种，还有一个故障状态Crash。",
      "elements_involved": [
