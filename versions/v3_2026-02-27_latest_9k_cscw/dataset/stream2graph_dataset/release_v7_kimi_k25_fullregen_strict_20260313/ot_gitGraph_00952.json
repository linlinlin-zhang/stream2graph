  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Git分支合并的示意图，展示多分支并行开发最后合并的流程。主分支叫branch_1，另外需要三个分支：branch_0、branch_2、branch_3，按0、1、2、3的顺序排列。",
      "elements_involved": [
        "branch_1",
        "branch_0",
        "branch_2",
