  "code": "flowchart BT\n    %% ===============================\n    %% Esquema_Queimadas\n    %% ===============================\n    subgraph Queimadas[\"Esquema_Queimadas\"]\n        dim_horarios_queimada[\"\n            <b>dim_horarios_queimada</b>\n            <hr>\n            id (PK)\n            hora\n            minuto\n        \"]\n\n        dim_data_queimada[\"\n            <b>dim_data_queimada</b>\n            <hr>\n            id (PK)\n            ano\n            mes\n            dia\n            semestre\n            trimestre\n            dia_semana\n            dia_ano\n            is_weekend\n            semana_ano\n            estacao\n        \"]\n\n        dim_local_queimada[\"\n            <b>dim_local_queimada</b>\n            <hr>\n            local_id (PK)\n            regiao_uf\n            sigla_uf\n            nome_uf\n            nome_municipio\n            id_municipio\n            latitude\n            longitude\n            bioma\n        \"]\n\n        fct_queimada[\"\n            <b>fct_queimada</b>\n            <hr>\n            data_fk (PK, FK)\n            local_fk (PK, FK)\n            hora_fk (PK, FK)\n            <hr>\n            risco_fogo\n            FRP\n            dias_sem_chuva\n        \"]\n    end\n\n    %% ===============================\n    %% Relationships\n    %% ===============================\n\n    %% Queimadas\n    dim_horarios_queimada -- hora_fk --> fct_queimada\n    dim_data_queimada -- data_fk --> fct_queimada\n    dim_local_queimada -- local_fk --> fct_queimada\n",
