    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "需要展开。Approved状态里，评论默认Visible，但用户可以Update变成Edited，编辑完再回到Visible。这个子状态的起点是RedisCache。Rejected状态类似，从EtcdCluster进入Hidden，然后可以Add Rejection Reason变成WithReason，最终也归档到RedisCache。",
      "elements_involved": [
        "Approved",
        "Visible",
        "Edited",
        "Update",
        "Infra_RedisCache",
        "Rejected",
        "Infra_EtcdCluster",
        "Hidden",
