    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，从初始节点 [*] 进入 Idle。另外当任务完成后，Active 应该能直接结束到终止节点 [*]。",
      "elements_involved": [
        "[*]",
        "Idle",
