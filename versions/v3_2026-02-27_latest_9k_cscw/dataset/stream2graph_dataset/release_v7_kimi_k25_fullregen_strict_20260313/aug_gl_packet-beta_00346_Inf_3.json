    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "需要，32-63放Sequence Number，64-95放Acknowledgment Number。还有Data Offset、Reserved、Window、Checksum、Urgent Pointer这些也都按标准来，别漏了。",
      "elements_involved": [
        "Sequence Number",
        "Acknowledgment Number",
        "Data Offset",
