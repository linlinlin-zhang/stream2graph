  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想做一个关于Netflix使用体验的饼图，讽刺一下找片两小时、看片五分钟的现象。标题就叫NETFLIX吧。",
      "elements_involved": [
