    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个云原生技术栈的演进流程图，从左到右展示从K8s集群到最终Serverless的完整链路。起点是K8sCluster，中间经过ServiceMesh和HelmChart，最后到Serverless。",
      "elements_involved": [
