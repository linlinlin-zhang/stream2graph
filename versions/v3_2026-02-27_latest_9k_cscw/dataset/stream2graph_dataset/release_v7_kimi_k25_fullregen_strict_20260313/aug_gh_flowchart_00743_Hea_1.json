      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "是的。然后c2诊断后如果Yes，走EMR同步c3到LabAnalyzer c4，最后回到c1更新记录。",
