      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "可以，ready状态要支持反复加载，包括LOAD_BASE、LOAD_LEFT、LOAD_RIGHT，这些都不改变状态，让用户能调整对比的基线。",
      "elements_involved": [
        "ready",
        "LOAD_BASE",
        "LOAD_LEFT",
        "LOAD_RIGHT"
      ],
      "is_repair": false
    },
    {
