    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Sessions部分比较复杂，A会话从12点持续63分钟，B在12点半开始12分钟，C是13:05开始12分钟，D从13:06开始33分钟——注意D和C几乎同时开始。",
      "elements_involved": [
        "A: 12:00:00, 63m",
        "B: 12:30:00, 12m",
        "C: 13:05:00, 12m",
        "D: 13:06:00, 33m"
