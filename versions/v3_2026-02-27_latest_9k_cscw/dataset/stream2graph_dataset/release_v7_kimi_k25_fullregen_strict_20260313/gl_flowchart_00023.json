  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要设计一个撤稿和勘误报告的提交流程。起点应该是用户，也就是Person节点。",
      "elements_involved": [
        "Person"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "好的，Person作为起点。那用户提交之后，第一步应该是什么？是一个表单吗？",
      "elements_involved": [
        "Person"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，需要一个REPORT节点，专门处理Report Retraction/Correction的表单提交。Person指向这个表单。",
      "elements_involved": [
        "Person",
        "REPORT"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加。现在REPORT之后需要验证吧？比如防机器人？",
      "elements_involved": [
        "REPORT",
        "CAPTCHA"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错，加个CAPTCHA判断节点。验证通过走YES分支，不通过直接进TRASH丢弃。",
      "elements_involved": [
        "CAPTCHA",
        "TRASH"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "CAPTCHA和TRASH都加上了。验证通过后进入自动分类环节？",
      "elements_involved": [
        "CAPTCHA",
        "AUTO_CLASSIFIER"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "是的，设计一个AUTO_CLASSIFIER节点，自动判断报告是否有效。YES的话进入人工复核，NO的话要通知用户。",
      "elements_involved": [
        "AUTO_CLASSIFIER",
        "C_CROWD",
        "NOTIFY_NO"
      ],
      "is_repair": false
    },
    {
      "turn_id": 8,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "人工复核用C_CROWD来表示吗？还有NOTIFY_NO是通知用户不通过？",
      "elements_involved": [
        "C_CROWD",
        "NOTIFY_NO"
      ],
      "is_repair": false
    },
    {
      "turn_id": 9,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，C_CROWD是众包复核环节。NOTIFY_NO就是通知Person审核未通过。而且NOTIFY_NO之后报告也要进TRASH。",
      "elements_involved": [
        "NOTIFY_NO",
        "TRASH"
      ],
      "is_repair": false
    },
    {
      "turn_id": 10,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "连接好了。那C_CROWD通过之后呢？",
      "elements_involved": [
        "C_CROWD",
        "NOTIFY_YES"
      ],
      "is_repair": false
    },
    {
      "turn_id": 11,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "C_CROWD通过的话，需要NOTIFY_YES通知用户通过，同时要把报告ADD_EVENT添加到Crossref。不通过的话回到NOTIFY_NO。",
      "elements_involved": [
        "NOTIFY_YES",
