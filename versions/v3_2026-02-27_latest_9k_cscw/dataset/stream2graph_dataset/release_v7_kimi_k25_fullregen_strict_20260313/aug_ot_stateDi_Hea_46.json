    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "COMPLETE之后发中断，IRQ sent回到IDLE。另外ERROR状态需要软件清除，SW clear也回到IDLE。两个终止状态都要能复位。",
      "elements_involved": [
