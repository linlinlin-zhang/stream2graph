      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认一下：COMPLETE到IDLE是IRQ sent，ERROR到IDLE是SW clear。那PARSE到ERROR的条件是Invalid，这个Invalid是指数据校验失败吗？",
      "elements_involved": [
        "COMPLETE",
        "IDLE",
        "ERROR",
        "IRQ sent",
