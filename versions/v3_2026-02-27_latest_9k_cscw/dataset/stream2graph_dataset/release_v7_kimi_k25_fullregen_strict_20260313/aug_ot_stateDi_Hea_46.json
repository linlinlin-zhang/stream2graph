        "FETCH",
        "COMPLETE",
        "Next",
        "Last"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我先把主干画出来：IDLE→FETCH→PARSE→ARB_READ→READ→ARB_WRITE→WRITE→CHAIN，然后CHAIN分支到FETCH和COMPLETE。COMPLETE之后呢？",
      "elements_involved": [
        "IDLE",
        "FETCH",
        "PARSE",
        "ARB_READ",
        "READ",
        "ARB_WRITE",
