      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "确认一下参与者的命名：A叫Frontend Application，B是App Builder Extension，C是Payment Gateway？另外支付完成后，网关是推webhook到Extension还是前端？",
      "elements_involved": [
        "Frontend Application",
        "App Builder Extension",
        "Payment Gateway",
        "webhook"
