    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加。现在Extension收到回调后，需要调回Frontend Application的getOrderByMaskedCartId方法，参数还是maskedCartId。",
