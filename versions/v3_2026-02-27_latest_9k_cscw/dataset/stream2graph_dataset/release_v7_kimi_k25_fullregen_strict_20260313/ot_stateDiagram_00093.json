  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个智能交通管理系统的状态图，核心是事故工单的生命周期。起点应该是新事故上报，然后进入Open状态。",
      "elements_involved": [
        "[*]",
        "Open",
        "New Incident Reported"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，Open状态我标注为\"New Incident Reported\"。接下来Open之后有哪些分支？是运营人员介入吗？",
      "elements_involved": [
        "Open",
        "Operator"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，运营人员确认后进入InReview审核状态。但还有一种情况是工单无效，直接Rejected结束。所以Open要分出两条线。",
      "elements_involved": [
        "Open",
        "InReview",
        "Rejected",
        "Operator acknowledges",
        "Invalid/Spam"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我画好了：Open到InReview标注\"Operator acknowledges\"，Open到Rejected标注\"Invalid/Spam\"。InReview之后呢？",
      "elements_involved": [
        "Open",
        "InReview",
        "Rejected",
        "Operator acknowledges",
        "Invalid/Spam"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "InReview之后，如果问题已解决就进入Resolved；但如果事故严重或需要上级授权，就要Escalated升级处理。",
      "elements_involved": [
        "InReview",
        "Resolved",
        "Escalated",
        "Issue cleared / verified fixed",
        "Severe or needs authority action"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认一下：Escalated之后也能到Resolved对吧？标注\"Action completed\"？然后Resolved和Rejected都指向终点？",
      "elements_involved": [
        "Escalated",
        "Resolved",
        "Rejected",
        "[*]",
        "Action completed"
      ],
      "is_repair": false
    },
    {
