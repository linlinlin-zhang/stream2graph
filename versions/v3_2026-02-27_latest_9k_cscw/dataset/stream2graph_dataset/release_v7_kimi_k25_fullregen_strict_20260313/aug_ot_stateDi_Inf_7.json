      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "确认一下：Suspended到Active是Issue resolved，Suspended到Deactivated是User or admin action，Active到Deactivated是User-initiated or admin action。最后Deactivated指向Infra_Cluster作为终点，对吗？",
      "elements_involved": [
        "Suspended",
