    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个简化版的金融系统流程图。核心是两个模块：一个是账本服务 FinTech_LedgerService，另一个是交易队列 FinTech_TransactionQueue。两者要有数据流向关系。",
      "elements_involved": [
