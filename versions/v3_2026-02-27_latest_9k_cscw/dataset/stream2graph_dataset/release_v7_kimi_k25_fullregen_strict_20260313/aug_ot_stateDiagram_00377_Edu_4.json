    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为Easy Park Plus的客户账户生命周期画一个状态图，场景是教育课堂服务。起点应该是Education LMS Portal，用户在那里注册账户。",
      "elements_involved": [
