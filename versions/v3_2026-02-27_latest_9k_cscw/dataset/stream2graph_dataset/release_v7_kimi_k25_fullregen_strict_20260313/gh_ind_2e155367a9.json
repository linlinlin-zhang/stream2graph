  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个任务状态流转图，从初始状态开始，先进入Idle状态，然后可以start触发到Processing。",
      "elements_involved": [
        "[*]",
        "Idle",
