  "code": "flowchart TD\n  %% Styling\n  classDef user fill:#E3F2FD,stroke:#90CAF9;\n  classDef assistant fill:#E8F5E9,stroke:#A5D6A7;\n  classDef decision fill:#FFF8E1,stroke:#FFD54F;\n  classDef app fill:#F3E5F5,stroke:#CE93D8;\n  classDef tool fill:#FBE9E7,stroke:#FFAB91;\n\n  %% User interaction\n  U[IoT_Industrial_TelemetryStream] --> A1[IoT_Industrial_PLC_Logic]\n\n  %% Assistant context\n  H1[IoT_Industrial_TelemetryStream] --> A1\n  A1 --> T1[IoT_Industrial_MQTT_Broker] --> A1\n\n  %% Ambiguity check\n  A1 --> D1{IoT_Industrial_MQTT_Broker}\n  D1 -- Yes --> C1[IoT_Industrial_ActuatorController] --> U\n  D1 -- No --> A2[IoT_Industrial_PLC_Logic]\n\n  %% Additional data check\n  A2 --> D2{IoT_Industrial_EdgeNode}\n  D2 -- Yes --> R1[IoT_Industrial_MQTT_Broker] --> APPD[IoT_Industrial_PLC_Logic]\n  D2 -- No --> AT\n\n  %% App execution\n  APPD --> AT[IoT_Industrial_MQTT_Broker]\n\n  %% Finalization paths\n  AT -- Needs App Execution --> APP_ACK[IoT_Industrial_PLC_Logic] --> U2[IoT_Industrial_ActuatorController]\n  AT -- No Execution Needed --> U2\n\n  %% Class tags\n  class U,U2 user\n  class A1,A2,C1,R1,R2,CALL,AT assistant\n  class D1,D2 decision\n  class APPD,APP_ACK app\n  class T1,H1 tool\n",
