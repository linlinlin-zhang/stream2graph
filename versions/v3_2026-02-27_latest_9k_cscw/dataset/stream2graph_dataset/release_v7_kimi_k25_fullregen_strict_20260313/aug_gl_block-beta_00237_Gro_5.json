    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Dana Wallet和Blindbit-Oracle之间的交互流程。核心场景是钱包如何同步比特币区块数据，同时保护隐私。三个主要参与者：Dana Wallet作为Scanner，Blindbit-Oracle作为中间层，还有Bitcoin Core Node作为数据源。",
      "elements_involved": [
        "Dana Wallet",
        "Blindbit-Oracle",
