  "code": "stateDiagram-v2\n[*] --> First\nFirst --> Second\nFirst --> Third\n\nstate \"the first composite\" as First {\n    [*] --> 1st\n    state innerFirst {\n      state \"1 in innerFirst\" as 1st1st\n      1st2nd: 2 in innerFirst\n      [*] --> 1st1st\n      1st1st --> 1st2nd\n      %% 1st2nd --> 1st\n    }\n    1st --> innerFirst\n    innerFirst --> 2nd\n}\nstate Second {\n    2nd --> [*]\n}\nstate Third {\n    [*] --> 3rd\n    3rd --> [*]\n}",
