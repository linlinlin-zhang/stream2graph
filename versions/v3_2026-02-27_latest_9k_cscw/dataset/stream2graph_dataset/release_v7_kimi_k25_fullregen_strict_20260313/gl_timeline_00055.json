    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个社交媒体平台发展的时间线，从2002年开始。第一个节点应该是LinkedIn，它是职业社交的先驱。",
      "elements_involved": [
