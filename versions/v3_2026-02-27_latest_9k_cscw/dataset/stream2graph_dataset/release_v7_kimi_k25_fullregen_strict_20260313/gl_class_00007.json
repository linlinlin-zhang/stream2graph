  "diagram_type": "class",
  "code": "classDiagram\n    Title -- Genre\n    Title *-- Season\n    Title *-- Review\n    Title o-- Actor\n\n    TVShow --|> Title\n    Short --|> Title\n    Film --|> Title\n\n    Season *-- Episode",
  "content_size": 182,
  "collected_at": "2026-02-06T10:56:38.323363",
