  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个去中心化交易所的流动性机制图，核心是想说明交易者、流动性提供者和代币数量之间的正负反馈关系。",
      "elements_involved": [
