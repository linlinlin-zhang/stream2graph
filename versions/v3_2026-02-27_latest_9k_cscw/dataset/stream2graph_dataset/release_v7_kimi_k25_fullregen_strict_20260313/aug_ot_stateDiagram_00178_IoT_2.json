  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为工业物联网边缘节点的任务生命周期建模。核心是从EdgeNode创建任务开始，经过几个关键状态流转，最终分发到MQTT Broker或Telemetry Stream。",
      "elements_involved": [
        "IoT_Industrial_EdgeNode",
        "IoT_Industrial_MQTT_Broker",
        "IoT_Industrial_TelemetryStream"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白了，所以起点是EdgeNode，终点有两个出口。那中间的主状态您打算怎么划分？我看到Created、InProgress这些关键词，是四层主状态吗？",
      "elements_involved": [
        "Created",
        "InProgress"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，四层主状态：Created创建后、InProgress进行中、OnHold挂起、Completed完成，再加上Cancelled取消作为异常出口。Created内部要有Draft和ReadyToStart两个子状态。",
      "elements_involved": [
        "Created",
        "Draft",
        "ReadyToStart",
        "InProgress",
        "OnHold",
        "Completed",
        "Cancelled"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我先把主框架画出来：EdgeNode触发Create Todo进入Created，然后Start Work到InProgress。Created里嵌套Draft，Draft通过Finalize变成ReadyToStart。",
      "elements_involved": [
        "IoT_Industrial_EdgeNode",
        "Created",
        "Create Todo",
        "Draft",
        "ReadyToStart",
        "Finalize",
        "InProgress",
        "Start Work"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "Draft到ReadyToStart的流转是对的。ReadyToStart完成后要流向Telemetry Stream，这是创建阶段的终点。另外Created也可以直接Cancel。",
      "elements_involved": [
        "ReadyToStart",
        "IoT_Industrial_TelemetryStream",
        "Created",
        "Cancelled"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加ReadyToStart到TelemetryStream的连线，以及Created的Cancel出口。现在处理InProgress内部：Started和InReview两个子状态，Submit for Review触发流转对吗？",
      "elements_involved": [
        "InProgress",
