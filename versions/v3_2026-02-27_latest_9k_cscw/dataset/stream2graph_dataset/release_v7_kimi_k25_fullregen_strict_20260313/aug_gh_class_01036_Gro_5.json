      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "另外还有个bc_fwx的数据处理链，这个比较复杂。bc_fwx本身对接看板，然后数据要流经一个format_wrapper。",
