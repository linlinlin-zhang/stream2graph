        "IDLE",
        "EV_CMD_START",
        "EV_CMD_STOP"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错。RAMP_UP达到目标值后进入ACTIVE正常运行，这时候可以响应EV_CMD_SET_PARAMS做参数调整，进入RAMP_CHANGE状态，等targets_reached再回到ACTIVE。",
      "elements_involved": [
