  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个记忆检索系统的状态流转图。用户一开始处于空闲状态，收到查询后进入回忆阶段。",
      "elements_involved": [
        "Idle",
        "Recall",
        "query"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "明白了，起点到Idle，然后Idle通过query事件触发到Recall。那回忆之后呢？有匹配到和没匹配到两种情况吧？",
      "elements_involved": [
        "[*]",
        "Idle",
        "Recall",
        "query"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，Recall如果match就进入Found状态，如果miss就进入NotFound。Found之后直接Apply应用这条记忆，然后Validate验证效果。",
      "elements_involved": [
        "Recall",
        "Found",
        "NotFound",
        "match",
        "miss",
        "Apply",
        "Validate"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好，我加上Found到Apply再到Validate。验证之后分成功和失败两条分支对吧？",
      "elements_involved": [
        "Found",
        "Apply",
        "Validate"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错，Validate成功的话走Strengthen强化这条记忆，失败的话走Weaken削弱它。两者最后都回到Idle等待下次查询。",
      "elements_involved": [
        "Validate",
        "Strengthen",
        "Weaken",
        "success",
        "fail",
        "Idle"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "那NotFound那条线呢？没匹配到记忆的时候怎么处理？",
      "elements_involved": [
        "NotFound"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "NotFound需要Solve解决问题，然后Capture捕获新记忆，最后也回到Idle。这样整个闭环就完成了。",
      "elements_involved": [
        "NotFound",
        "Solve",
        "Capture",
        "Idle"
      ],
      "is_repair": false
    },
    {
