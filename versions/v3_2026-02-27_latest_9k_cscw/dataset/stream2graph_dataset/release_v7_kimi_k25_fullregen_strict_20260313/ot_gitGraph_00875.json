    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Git分支合并的流程图，展示从master切出feature分支，开发完再合并回去的典型场景。",
      "elements_involved": [
        "master",
        "feature",
