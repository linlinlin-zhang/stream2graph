        "on_frame_sent"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "propose",
      "utterance": "我打算把起点设为MQTT Broker，第一个状态叫INIT。当on_connected事件触发时进入HANDSHAKING。这样命名可以吗？",
