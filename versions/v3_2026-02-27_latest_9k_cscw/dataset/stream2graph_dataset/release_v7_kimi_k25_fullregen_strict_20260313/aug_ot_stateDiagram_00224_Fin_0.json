    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "scanned之后有两个主要动作：继续SCAN可以刷新列表保持在scanned，或者用SELECT进入viewing状态查看具体条目。另外从viewing可以BACK返回scanned。",
      "elements_involved": [
