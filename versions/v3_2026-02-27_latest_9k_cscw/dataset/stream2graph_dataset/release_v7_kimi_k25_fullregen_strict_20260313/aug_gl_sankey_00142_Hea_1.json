  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为HealthTech_LabAnalyzer项目做一个能源流向图。目前有三种能源来源：电网电力、天然气，还有我们新上的太阳能板。我想用桑基图来展示它们分别流向住宅、商业和工业这三大终端的情况。",
