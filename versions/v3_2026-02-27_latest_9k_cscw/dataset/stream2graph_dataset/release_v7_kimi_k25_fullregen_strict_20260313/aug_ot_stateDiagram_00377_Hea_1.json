      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "先Registered，需要等用户完成邮箱验证或者身份认证才能变成Active。所以Registered到Active的触发条件是Email/identity verified。",
      "elements_involved": [
        "Registered",
