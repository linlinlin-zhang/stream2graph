      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "clarify",
      "utterance": "对，把feature的order设为0，让它显示在左边。然后切回main做提交b，再切到feature做提交i。",
