  "code": "C4Context\n    Person(respondente, \"Respondente\", \"Pessoa que responde as pesquisas atraves de links em redes sociais\")\n    Person(admin, \"Administrador\", \"Usuario que cria pesquisas e visualiza resultados\")\n\n    System(sistema, \"Sistema de Questionarios Online\", \"Permite criar pesquisas, coletar respostas em escala e visualizar resultados sumarizados\")\n\n    System_Ext(redes, \"Redes Sociais\", \"Facebook, Instagram, Twitter - divulgacao das pesquisas\")\n    System_Ext(cdn, \"CDN\", \"Distribuicao de conteudo estatico\")\n\n    Rel(respondente, sistema, \"Responde pesquisas\", \"HTTP\")\n    Rel(admin, sistema, \"Gerencia pesquisas e visualiza resultados\", \"HTTP\")\n    Rel(sistema, redes, \"Links compartilhados\")\n    Rel(cdn, respondente, \"Entrega conteudo estatico\")\n",
