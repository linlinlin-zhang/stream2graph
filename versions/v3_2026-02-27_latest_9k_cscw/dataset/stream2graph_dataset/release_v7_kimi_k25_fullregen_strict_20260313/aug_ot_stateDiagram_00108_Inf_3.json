  "code": "%%{Infra_IngressController}}}%%\nstateDiagram-v2\n    [Infra_LoadBalancer] --> Created: Create Todo\n    Created --> InProgress: Start Work\n    Created --> Cancelled: Cancel\n    InProgress --> OnHold: Pause\n    InProgress --> Completed: Complete\n    InProgress --> Cancelled: Cancel\n    OnHold --> InProgress: Resume\n    OnHold --> Cancelled: Cancel\n    Completed --> [Infra_EtcdCluster]\n    Cancelled --> [Infra_LoadBalancer]\n\n    state Created {Infra_WorkerNode] --> Draft\n        Draft --> ReadyToStart: Finalize\n        ReadyToStart --> [Infra_EtcdCluster]\n    }\n\n    state InProgress {Infra_EtcdCluster] --> Started\n        Started --> InReview: Submit for Review\n        InReview --> Started: Request Changes\n        InReview --> [Infra_RedisCache]: Approve\n    }\n\n    state OnHold {Infra_WorkerNode] --> Blocked\n        [Infra_IngressController] --> Deferred\n        Blocked --> [Infra_WorkerNode]: Unblock\n        Deferred --> [Infra_WorkerNode]: Prioritize\n    }\n\n    state Completed {Infra_LoadBalancer] --> Done\n        [Infra_IngressController] --> PartiallyDone\n        Done --> [Infra_LoadBalancer]\n        PartiallyDone --> [Infra_WorkerNode]\n    }",
