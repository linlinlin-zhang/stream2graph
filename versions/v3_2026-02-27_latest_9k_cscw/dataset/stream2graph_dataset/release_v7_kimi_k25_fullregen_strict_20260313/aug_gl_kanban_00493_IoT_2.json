  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为工业物联网场景设计一个看板，核心是要体现数据从现场设备到云端控制的完整链路。第一列我想放ActuatorController，这是整个系统的执行中枢。",
      "elements_involved": [
