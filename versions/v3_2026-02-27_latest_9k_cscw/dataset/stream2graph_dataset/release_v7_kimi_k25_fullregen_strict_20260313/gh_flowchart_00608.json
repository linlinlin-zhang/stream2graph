    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为第七章绘制一个流程图，主题是罗得妻子的疏散决策。核心冲突是她面临的选择：向前看还是回头看。",
      "elements_involved": [
