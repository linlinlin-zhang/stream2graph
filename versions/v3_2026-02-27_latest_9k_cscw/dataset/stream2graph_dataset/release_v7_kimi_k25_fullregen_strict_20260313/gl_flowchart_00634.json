  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个CPU指令周期的流程图，从复位开始，经过取指、译码、执行、写回，最后检查是否停机。这个要展示经典的冯·诺依曼循环。",
      "elements_involved": [
        "Start",
        "Fetch",
