      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个链上交易提交流程图，从用户发起请求开始，到最终返回交易哈希结束。核心是要体现地址校验这个关键风控点。",
      "elements_involved": [
        "Start",
