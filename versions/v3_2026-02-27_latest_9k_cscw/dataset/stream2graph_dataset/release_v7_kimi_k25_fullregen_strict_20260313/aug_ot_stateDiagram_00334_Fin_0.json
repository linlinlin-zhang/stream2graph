  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想设计一个游戏流程的状态图，核心是FinTech_TransactionQueue作为起点，先进入Lobby状态。玩家在这里等待，然后由Host触发开始。",
      "elements_involved": [
