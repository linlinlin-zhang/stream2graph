    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，Manager直接分配到Colegio，状态变为AsignadoColegio。然后Colegio的代表再分配给具体的Perito。",
      "elements_involved": [
        "AsignadoColegio",
        "AsignadoPerito",
