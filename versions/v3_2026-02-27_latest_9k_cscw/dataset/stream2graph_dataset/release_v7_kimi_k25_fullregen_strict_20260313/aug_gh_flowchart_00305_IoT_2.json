      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，现在CDN层是Edge、Lambda、证书、缓存，类型分别是EdgeNode、TelemetryStream、EdgeNode、ActuatorController。",
      "elements_involved": [
        "EDGE",
        "LAMBDA",
        "CERT",
        "CACHE"
      ],
      "is_repair": false
