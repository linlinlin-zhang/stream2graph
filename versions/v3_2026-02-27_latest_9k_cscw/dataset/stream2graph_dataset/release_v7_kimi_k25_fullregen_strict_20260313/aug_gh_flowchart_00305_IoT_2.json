    {
      "turn_id": 20,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "再确认一下命名一致性：DNS子图里的R53是TelemetryStream，但子图标题是ActuatorController，这个对应关系正确吗？",
      "elements_involved": [
        "DNS",
        "R53",
        "IoT_Industrial_ActuatorController",
