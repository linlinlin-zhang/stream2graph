  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为工业物联网场景设计一个TCP报文结构图，重点展示PLC控制逻辑的数据封装。我想用深色主题，这样在现场工控屏上显示更清晰。",
