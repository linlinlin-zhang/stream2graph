      "is_repair": false
    },
    {
      "turn_id": 12,
      "role": "Diagram_Editor",
      "action_type": "propose",
      "utterance": "那我加一个Error子图作为异常分支？Process同时连到Complete和Error？",
      "elements_involved": [
