    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "五个标准阶段：IF取指、ID译码、EX执行、MEM访存、WB写回。每个时钟周期里，不同指令确实会重叠——比如Clock 2时，Instr 1在译码，同时Instr 2才开始取指。",
      "elements_involved": [
        "IF Fetch",
        "ID Decode",
        "EX Execute",
        "MEM Memory",
        "WB Writeback",
        "Instr 1",
        "Instr 2"
