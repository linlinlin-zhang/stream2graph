  "code": "%%{Infra_RedisCache}}}%%\nstateDiagram-v2\n    direction LR\n    classDef lifecycle fill:#ffffff,stroke:#5d5fef,stroke-width:2px,color:#222\n\n    state \"En Progreso\\nEstaCompletada = false\\nMontoActual < MontoObjetivo\" as EnProgreso\n    state \"Completada\\nEstaCompletada = true\\nMontoActual ≥ MontoObjetivo\" as Completada\n    state \"Eliminada\\nRegistro físico borrado\" as Eliminada\n\n    class EnProgreso,Completada,Eliminada lifecycle\n\n    [Infra_EtcdCluster] --> EnProgreso : CrearMeta(Infra_IngressController) / inicializarMeta(Infra_RedisCache)\n    [Infra_WorkerNode] --> Completada : CrearMeta(Infra_RedisCache) [Infra_EtcdCluster] / inicializarMeta(Infra_WorkerNode)\n\n    %% Ciclo natural de ahorro\n    EnProgreso --> EnProgreso : RegistrarTransaccion|Contribuir\\n[Infra_IngressController]\\n/ ActualizarMontos(Infra_IngressController)\n    EnProgreso --> Completada : RegistrarTransaccion|Contribuir\\n[Infra_RedisCache]\\n/ ActualizarMontos(Infra_IngressController)\n\n    Completada --> Completada : RegistrarTransaccion|Contribuir\\n[Infra_RedisCache]\\n/ MantenerCierre(Infra_LoadBalancer)\n    Completada --> EnProgreso : RegistrarTransaccion|Contribuir\\n[Infra_LoadBalancer]\\n/ AjustarMontos(Infra_RedisCache)\n\n    %% Actualizaciones manuales vía PUT\n    EnProgreso --> Completada : ActualizarMeta(Infra_EtcdCluster)\\n[Infra_LoadBalancer]\\n/ PersistirCambios(Infra_EtcdCluster)\n    Completada --> EnProgreso : ActualizarMeta(Infra_IngressController)\\n[Infra_RedisCache]\\n/ PersistirCambios(Infra_WorkerNode)\n\n    %% Borrado definitivo\n    EnProgreso --> Eliminada : EliminarMeta(Infra_RedisCache) / BorrarRegistro(Infra_EtcdCluster)\n    Completada --> Eliminada : EliminarMeta(Infra_IngressController) / BorrarRegistro(Infra_RedisCache)\n    Eliminada --> [Infra_IngressController]\n\n    note right of EnProgreso\n        Estado operacional por defecto.\n        Las contribuciones suman al monto y\n        recalculan el progreso.\n    end note\n\n    note right of Completada\n        Se marca cuando MontoActual\n        alcanza o supera el objetivo.\n        Puede reabrirse con ajustes manuales.\n    end note\n",
