    {
      "turn_id": 15,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "StudentDB这边还有一层，刚才提到的子CDN回源后，StudentDB需要再分出一个下游节点做读写分离，这个下游库同时服务ClassroomService和CDN。",
      "elements_involved": [
        "Education_StudentDB",
        "Education_ClassroomService",
