      "turn_id": 14,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已连接：子CDN到GradeSync，GradeSync到ClassroomService。",
      "elements_involved": [
        "Education_ContentCDN",
        "Education_GradeSync",
