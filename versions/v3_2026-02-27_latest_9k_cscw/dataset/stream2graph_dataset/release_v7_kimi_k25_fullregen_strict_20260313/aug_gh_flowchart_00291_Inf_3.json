  "diagram_type": "flowchart",
  "code": "flowchart TD\n  %% Styling\n  classDef user fill:#E3F2FD,stroke:#90CAF9;\n  classDef assistant fill:#E8F5E9,stroke:#A5D6A7;\n  classDef decision fill:#FFF8E1,stroke:#FFD54F;\n  classDef app fill:#F3E5F5,stroke:#CE93D8;\n  classDef tool fill:#FBE9E7,stroke:#FFAB91;\n\n  %% User interaction\n  U[Infra_LoadBalancer] --> A1[Infra_WorkerNode]\n\n  %% Assistant context\n  H1[Infra_LoadBalancer] --> A1\n  A1 --> T1[Infra_IngressController] --> A1\n\n  %% Ambiguity check\n  A1 --> D1{Infra_IngressController}\n  D1 -- Yes --> C1[Infra_WorkerNode] --> U\n  D1 -- No --> A2[Infra_LoadBalancer]\n\n  %% Additional data check\n  A2 --> D2{Infra_EtcdCluster}\n  D2 -- Yes --> R1[Infra_IngressController] --> APPD[Infra_EtcdCluster]\n  D2 -- No --> AT\n\n  %% App execution\n  APPD --> AT[Infra_EtcdCluster]\n\n  %% Finalization paths\n  AT -- Needs App Execution --> APP_ACK[Infra_LoadBalancer] --> U2[Infra_EtcdCluster]\n  AT -- No Execution Needed --> U2\n\n  %% Class tags\n  class U,U2 user\n  class A1,A2,C1,R1,R2,CALL,AT assistant\n  class D1,D2 decision\n  class APPD,APP_ACK app\n  class T1,H1 tool\n",
