    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个甘特图来展示Round Robin调度算法的第一部分，时间范围是0到15秒，时间片q=3。",
      "elements_involved": [
        "0 15s",
