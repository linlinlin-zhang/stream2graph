  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个信任更新的流程图，核心是维护者如何对代码树进行多签。起点是有人提交了一个信任更新提案。",
      "elements_involved": [
