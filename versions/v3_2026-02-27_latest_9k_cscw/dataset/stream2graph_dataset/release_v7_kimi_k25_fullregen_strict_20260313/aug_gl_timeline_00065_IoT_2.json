  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要一个时间线图来展示国际国家代码的演变历程。重点是ISO 3166标准从1974年第一版开始的迭代，以及北约在2004年转向采用ISO标准这个关键转折点。",
