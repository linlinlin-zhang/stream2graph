      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "还有异常流程：Moving状态下可能发生Crash，Crash之后需要同步到Education_GradeSync进行成绩数据的最终归档。",
      "elements_involved": [
