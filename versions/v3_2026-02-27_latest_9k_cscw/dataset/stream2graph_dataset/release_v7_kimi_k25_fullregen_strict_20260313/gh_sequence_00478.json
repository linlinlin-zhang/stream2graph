      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Alice 说\"Hello John, how are you?\"，用实线箭头就行，这是普通的问候。然后 John 回复\"Great!\"，用虚线箭头表示返回。",
      "elements_involved": [
