    {
      "turn_id": 17,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "评论还有一个重要状态——可以被举报。这个和采纳是互斥的，同一条评论不会同时被采纳又被举报。",
      "elements_involved": [
        "Comment",
        "Reported"
      ],
      "is_repair": false
