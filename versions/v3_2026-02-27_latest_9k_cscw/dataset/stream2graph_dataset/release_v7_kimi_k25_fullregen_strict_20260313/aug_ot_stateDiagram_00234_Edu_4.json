    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "Connected之后也要能断开，需要一条disconnect回到Idle。还有，通话中要有保留功能，从Connected可以进入OnHold状态。",
      "elements_involved": [
        "Connected",
