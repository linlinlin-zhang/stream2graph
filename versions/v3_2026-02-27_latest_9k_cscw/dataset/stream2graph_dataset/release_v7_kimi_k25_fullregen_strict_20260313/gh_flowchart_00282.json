  "diagram_type": "flowchart",
  "code": "%%{init: {\n  \"theme\": \"base\",\n  \"themeVariables\": {\n    \"fontFamily\": \"Inter, Arial, sans-serif\",\n    \"fontSize\": \"14px\",\n    \"lineColor\": \"#444444\"\n  }\n}}%%\n\nflowchart LR\n  Community[\"Community\"]:::neutral --> GP[\"GP / primary care\"]:::cth\n  Community --> ED_Arrival[\"ED arrival\"]:::neutral\n  GP --> ED_Arrival\n\n  ED_Arrival --> ED_Treat[\"ED assessment & treatment\"]:::state\n  ED_Treat --> Admission[\"Decision to admit\"]:::neutral\n  Admission --> Inpatient[\"Inpatient stay\"]:::state\n  Inpatient --> Ready[\"Ready for discharge\"]:::neutral\n\n  %% Blockages (constraints)\n  Ready --> Block_Aged[\"Aged care placement<br>(capacity constraint)\"]:::risk\n  Ready --> Block_NDIS[\"NDIS supports / accommodation<br>(delay / mismatch)\"]:::risk\n\n  %% Feedback loop (access block mechanism)\n  Block_Aged -.->|\"occupancy feedback loop\"| Inpatient\n\n  %% Optional: show the ED consequence explicitly\n  Inpatient -.->|\"high occupancy limits flow\"| ED_Treat\n\n  classDef cth fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#111;\n  classDef state fill:#ffebee,stroke:#b71c1c,stroke-width:2px,color:#111;\n  classDef risk fill:#fff3e0,stroke:#e65100,stroke-width:2px,stroke-dasharray: 6 4,color:#111;\n  classDef neutral fill:#f5f5f5,stroke:#777,color:#111;",
