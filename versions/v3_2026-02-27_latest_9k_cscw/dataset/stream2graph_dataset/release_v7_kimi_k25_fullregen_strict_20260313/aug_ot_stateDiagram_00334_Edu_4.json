    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "清楚了，AnswerValidation有两个出口。那游戏怎么结束呢？是题目出完就自动结束，还是主持人手动控制？",
      "elements_involved": [
