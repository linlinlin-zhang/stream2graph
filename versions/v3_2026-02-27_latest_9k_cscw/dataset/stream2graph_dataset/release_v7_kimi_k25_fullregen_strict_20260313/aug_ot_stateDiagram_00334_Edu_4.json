    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错，学生抢答后进入AnswerValidation状态验证答案。这里有两个分支：答对了回到QuestionPrep准备下一题，答错了返回QuestionActive让其他人继续抢。",
      "elements_involved": [
