    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要梳理一下教育系统的数据流向。核心是从LMS门户开始，学生数据库作为中间层，最后到成绩同步模块。整体想做成从左到右的流程图。",
      "elements_involved": [
