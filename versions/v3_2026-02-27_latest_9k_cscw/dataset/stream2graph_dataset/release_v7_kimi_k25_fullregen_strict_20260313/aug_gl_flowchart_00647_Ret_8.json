  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要梳理一下零售优惠券系统的整体流程。从Retail_CouponSystem开始，它首先要经过Retail_OrderManagement的判断节点。",
