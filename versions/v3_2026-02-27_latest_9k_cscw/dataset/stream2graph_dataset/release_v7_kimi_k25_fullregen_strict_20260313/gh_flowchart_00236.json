      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "收到，处理节点用矩形[Raw Ingestion]、[Processed Data Generation]，判断节点用菱形{Raw Validation}、{Processed Validation}，终止节点保持矩形但带颜色样式。",
      "elements_involved": [
        "INGEST",
        "PROCESS",
        "RAWVAL",
        "PROCVAL"
