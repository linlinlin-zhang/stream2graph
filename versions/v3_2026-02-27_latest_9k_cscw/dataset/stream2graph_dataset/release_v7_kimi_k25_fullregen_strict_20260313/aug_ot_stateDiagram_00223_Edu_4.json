    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "还有一个关键场景：维护模式。三个状态都应该能进入Maintenance，触发条件是Enter maintenance mode。",
      "elements_involved": [
