    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为Easy Park Plus系统画一个状态图，核心是停车场从空到满的流转逻辑。初始状态应该是EmptyLot，表示没有车辆停放。",
      "elements_involved": [
