  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个简单的状态流转图，描述一个样本对象的生命周期。它一开始是静止状态，可以变成移动状态，但移动中可能会崩溃。",
      "elements_involved": [
        "Still",
        "Moving",
        "Crash",
        "state transition"
