      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "两位审稿人各自独立向区块链提交投票。投票类型有五种：accept、reject、feedback、refer、skip。注意这是commit vote，意味着投票一旦上链就不可篡改。",
      "elements_involved": [
