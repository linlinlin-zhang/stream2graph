      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "有两种方式。一种是标准的Mobility DSL：translates hero_image with backend: :attachments。另一种是我们扩展的快捷语法：translates_attached :hero_image。",
      "elements_involved": [
        "ModelCanonical",
        "ModelDSL",
        "Apply"
