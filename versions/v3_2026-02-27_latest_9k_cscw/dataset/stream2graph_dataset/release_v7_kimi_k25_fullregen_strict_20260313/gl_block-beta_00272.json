  "code": "%%{init: {\n  \"theme\": \"base\",\n  \"flowchart\": { \"curve\": \"basis\", \"nodeSpacing\": 60, \"rankSpacing\": 85, \"padding\": 10 },\n  \"themeVariables\": {\n    \"fontFamily\": \"Inter, Arial, sans-serif\",\n    \"fontSize\": \"14px\",\n    \"lineColor\": \"#333333\",\n    \"textColor\": \"#111111\"\n  }\n}}%%\n\nflowchart LR\n  V([\"Vertical fiscal imbalance<br>(Commonwealth revenue; States run hospitals)\"]):::core\n  T[\"NHRA funding terms<br>(price basis, caps,<br>nominal vs effective share)\"]:::cw\n  I[\"Split incentives<br>(cost-shifting;<br>no end-to-end owner)\"]:::neutral\n  X[\"Exit block<br>(discharge failure across<br>Aged Care/NDIS/community)\"]:::neutral\n  R[\"Clinical risk<br>(ED overcrowding, delays,<br>staff harm, adverse events)\"]:::risk\n\n  V --> T --> I --> X --> R\n\n  F1[\"Pooled/Regional funding pilots<br>(shared accountability + outcomes)\"]:::st\n  F2[\"Integrated clinical governance<br>(end-to-end responsibility;<br>data/reporting)\"]:::st\n  F3[\"Middle-tier workforce + subacute pathways<br>(unlock discharge)\"]:::st\n\n  F1 -. reduces .-> I\n  F2 -. mitigates .-> R\n  F3 -. reduces .-> X\n\n  classDef core fill:#FFF4CC,stroke:#8A6D00,color:#111,stroke-width:2px;\n  classDef cw fill:#E8F0FE,stroke:#3B6FB6,color:#111;\n  classDef st fill:#E9FFF1,stroke:#2F8F5B,color:#111;\n  classDef neutral fill:#F5F5F5,stroke:#777,color:#111;\n  classDef risk fill:#FFE8E8,stroke:#B84A4A,color:#111;",
