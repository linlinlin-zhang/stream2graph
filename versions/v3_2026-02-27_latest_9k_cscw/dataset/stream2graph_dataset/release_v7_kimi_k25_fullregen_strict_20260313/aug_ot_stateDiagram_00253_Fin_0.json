    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白了，Pending之后有两个分支对吧？一个是审批通过变成Confirmed，另一个是被拒绝。拒绝的状态需要连到哪里吗？",
      "elements_involved": [
