    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为GradeSync教育平台设计一个核心概念图。我觉得应该以\"Education_GradeSync\"作为整个系统的根节点，这是一个成绩同步与学业管理的综合平台。",
      "elements_involved": [
