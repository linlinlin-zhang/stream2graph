        "Complete",
        "Grant"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "CHAIN之后有两个出口吧？一个是继续下一条数据，一个是全部完成？",
