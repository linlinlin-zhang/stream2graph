    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个基于访问令牌的OAuth 2.0认证流程图，核心要体现用户如何通过Identity Provider获取权限，最终访问Resource Server。",
      "elements_involved": [
