      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "异常情况需要单独处理。如果解析过程中出现error，直接从NeedMore跳转到Error状态终止流程。",
      "elements_involved": [
        "NeedMore",
        "Error",
        "error"
