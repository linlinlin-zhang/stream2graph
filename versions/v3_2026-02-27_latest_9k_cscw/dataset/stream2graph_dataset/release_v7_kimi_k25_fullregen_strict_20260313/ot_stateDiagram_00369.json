  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个发票支付的状态流转图。起点是创建发票后进入PENDING状态，用户有1小时付款时间，超时自动过期。",
      "elements_involved": [
        "[*]",
        "PENDING",
        "EXPIRED",
        "Invoice Created",
        "Timeout Reached"
      ],
      "is_repair": false
    },
    {
      "turn_id": 2,
      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，PENDING状态需要加个备注说明1小时有效期。那用户主动取消的情况呢？",
      "elements_involved": [
        "PENDING",
        "CANCELLED",
        "User Cancelled"
      ],
      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，PENDING可以转到CANCELLED。另外用户发起支付后进入PROCESSING，这个状态要说明交易正在验证中。",
      "elements_involved": [
        "PENDING",
        "PROCESSING",
        "Payment Initiated",
        "COMPLETED",
        "FAILED"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "已添加PROCESSING状态和相关流转。PROCESSING成功后到COMPLETED，失败的话到FAILED对吧？",
      "elements_involved": [
        "PROCESSING",
        "COMPLETED",
        "FAILED",
        "Payment Verified",
        "Payment Error"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "是的，但FAILED比较特殊——如果是可重试的错误，要能回到PENDING让用户重新支付。",
      "elements_involved": [
        "FAILED",
        "PENDING",
        "Retry Payment",
        "retryable"
      ],
      "is_repair": false
    },
    {
      "turn_id": 6,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，FAILED到PENDING的回流已加，备注也写了Retryable errors。那退款流程呢？",
      "elements_involved": [
        "FAILED",
        "PENDING",
        "COMPLETED",
        "PARTIALLY_REFUNDED",
        "REFUNDED"
      ],
      "is_repair": false
    },
    {
      "turn_id": 7,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "COMPLETED之后可以部分退款或全额退款。部分退款后如果还有剩余金额，可以继续退到全额。",
      "elements_involved": [
        "COMPLETED",
        "PARTIALLY_REFUNDED",
        "REFUNDED",
        "Partial Refund",
        "Full Refund",
        "Remaining Refund"
