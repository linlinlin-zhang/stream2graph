  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Alice和Bob的日常问候流程。场景是Alice每天向Bob问好，然后Bob根据身体状况给出不同回复。",
      "elements_involved": [
        "Alice",
        "Bob",
