    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，2017年是Byzantium，2021年比较特殊，Constantinople和London是同一年但不同时间发布的，所以那一行我想标注两个名字。",
      "elements_involved": [
        "2017",
        "Byzantium",
        "2021",
        "Constantinople",
        "London"
      ],
      "is_repair": false
    },
    {
      "turn_id": 4,
      "role": "Diagram_Editor",
      "action_type": "confirm",
      "utterance": "好的，2021年同时显示Constantinople和London。那Merge部分呢？",
      "elements_involved": [
        "section Merge",
        "2022",
        "The Merge"
      ],
      "is_repair": false
    },
    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "Merge部分就2022年一个事件：The Merge。然后Post-Merge从2023年开始，每年一个升级——Shapella、Dencun、Pectra、Fusaka，一直到2026年。",
      "elements_involved": [
        "section Post-Merge",
        "2023",
        "Shapella",
        "2024",
        "Dencun",
        "2025",
        "Pectra",
        "2026",
