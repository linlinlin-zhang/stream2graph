  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想做一个以太坊升级的时间线图，展示从2017年到2026年的关键里程碑。整体分成三个阶段：Merge之前、Merge本身、以及Merge之后。",
      "elements_involved": [
