      "is_repair": false
    },
    {
      "turn_id": 13,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "最后是Completed完成状态，要区分完全完成和部分完成两种情况，分别关联优惠券系统和库存系统。",
