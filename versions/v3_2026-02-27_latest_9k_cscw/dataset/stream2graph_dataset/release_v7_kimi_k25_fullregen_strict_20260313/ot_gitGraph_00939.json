    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个Git流程图，展示两个特性分支并行开发然后合并回主干的过程。主干叫main，两个分支分别是feature_1和feature_2。",
      "elements_involved": [
