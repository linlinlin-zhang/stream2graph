        "Computadora B",
        "Computadora C",
        "Computadora D",
        "ARP Request",
        "Retail_OrderManagement",
        "Retail_PointOfSale",
        "Retail_Inventory"
      ],
      "is_repair": false
    },
    {
      "turn_id": 12,
      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "三条广播消息都画好了。接下来应该标注只有C会响应？",
