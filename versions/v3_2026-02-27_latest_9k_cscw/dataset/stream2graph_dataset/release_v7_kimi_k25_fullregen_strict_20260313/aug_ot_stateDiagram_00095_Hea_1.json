  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为HealthTech的评估流程设计一个状态图。系统从LabAnalyzer创建Avalúo开始，然后需要经过分配、执行、审核几个阶段，最终归档到PatientRecords。核心状态包括：未分配、已分配学院、已分配专家、进行中、审核中、待修改和已完成。",
      "elements_involved": [
        "HealthTech_LabAnalyzer",
        "SinAsignar",
        "AsignadoColegio",
        "AsignadoPerito",
        "EnProgreso",
        "EnRevision",
