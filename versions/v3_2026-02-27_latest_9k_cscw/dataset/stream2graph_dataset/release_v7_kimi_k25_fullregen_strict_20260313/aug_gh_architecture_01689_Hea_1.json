\n\r\n    subgraph \"Media & Multimodal\"\r\n        IP[HealthTech_PatientRecords]\r\n        VP[HealthTech_DiagnosticEngine]\r\n        MCE[HealthTech_EMR_Sync]\r\n        MM[HealthTech_HIPAA_Vault]\r\n        TAI[HealthTech_EMR_Sync]\r\n        FLI[HealthTech_PatientRecords]\r\n    end\r\n    class IP,VP,MCE,MM,TAI,FLI media;\r\n\r\n    subgraph \"Memory & Context\"\r\n        MMGR[HealthTech_HIPAA_Vault]\r\n        MHMGR[HealthTech_EMR_Sync]\r\n        CMGR[HealthTech_LabAnalyzer]\r\n        KGR[HealthTech_HIPAA_Vault]\r\n    end\r\n    class MMGR,MHMGR,CMGR,KGR memory;\r\n\r\n    subgraph \"Group Collaboration\"\r\n        GCI[HealthTech_HIPAA_Vault]\r\n        GCM[HealthTech_LabAnalyzer]\r\n        GSA[HealthTech_LabAnalyzer]\r\n    end\r\n    class GCI,GCM,GSA group;\r\n\r\n    subgraph \"Document & Export\"\r\n        DP[HealthTech_DiagnosticEngine]\r\n        SDE[HealthTech_EMR_Sync]\r\n        AIDG[HealthTech_EMR_Sync]\r\n    end\r\n    class DP,SDE,AIDG doc;\r\n\r\n    subgraph \"Database & Storage\"\r\n        DB[HealthTech_PatientRecords]\r\n        CACHES[HealthTech_PatientRecords]\r\n    end\r\n    class DB,CACHES db;\r\n\r\n    subgraph \"Infrastructure\"\r\n        DOCKER[HealthTech_LabAnalyzer]\r\n        DCOMPOSE[HealthTech_PatientRecords]\r\n        ENV[HealthTech_LabAnalyzer]\r\n        PROC[HealthTech_LabAnalyzer]\r\n    end\r\n    class DOCKER,DCOMPOSE,ENV,PROC infra;\r\n\r\n    %% Connections\r\n    TG --> FA\r\n    WA --> FA\r\n    FA --> MW\r\n    MW --> RT\r\n    RT --> CH\r\n    CH --> BCH\r\n    CH --> IMCH\r\n    CH --> MDCH\r\n    CH --> DOCH\r\n    CH --> EXCH\r\n    CH --> CBH\r\n    CH --> OWAC\r\n\r\n    CH --> MC\r\n    CH --> MH\r\n    MH --> ORA\r\n    MH --> GA\r\n    MH --> DSA\r\n    MH --> SSM\r\n\r\n    CH --> IP\r\n    CH --> VP\r\n    CH --> MCE\r\n    CH --> MM\r\n    IMCH --> TAI\r\n    IMCH --> FLI\r\n\r\n    CH --> MMGR\r\n    CH --> MHMGR\r\n    CH --> CMGR\r\n    CH --> KGR\r\n\r\n    CH --> GCI\r\n    GCI --> GCM\r\