  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我想画一个用户旅程图，记录我典型的工作日流程。整体分成两大块：早上去上班的过程，以及晚上回家的过程。",
      "elements_involved": [
