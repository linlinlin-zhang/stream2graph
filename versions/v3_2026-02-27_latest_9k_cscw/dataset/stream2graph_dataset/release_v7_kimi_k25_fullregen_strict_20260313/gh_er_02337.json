      "is_repair": false
    },
    {
      "turn_id": 21,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "还需要库存ID系统。我们要定义INVENTORY-ID-SCHEMA作为编码规则，然后ITEM和PRODUCT可以有具体的INVENTORY-ID。",
      "elements_involved": [
