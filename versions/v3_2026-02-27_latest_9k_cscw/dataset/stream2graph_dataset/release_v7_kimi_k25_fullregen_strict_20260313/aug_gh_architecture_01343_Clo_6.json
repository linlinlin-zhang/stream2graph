    {
      "turn_id": 5,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "没错，主链路是C1--C2--P1--S1。然后服务端内部S1要分出两条支路：一条是S1--S2--S3--S5，另一条是S2--S4--S5，最后都汇聚到S5。",
      "elements_involved": [
