      "is_repair": false
    },
    {
      "turn_id": 15,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "对，加一个ARB做MonBus Arbiter，两个client输入，输出统一格式。DESC_MON和SCHED_MON都连到ARB。",
