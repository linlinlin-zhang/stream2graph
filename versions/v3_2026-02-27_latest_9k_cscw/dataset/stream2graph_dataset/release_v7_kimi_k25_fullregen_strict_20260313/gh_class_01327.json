  "code": "%% Class Diagram Template\n%% Replace with your actual data model\n\nclassDiagram\n    class User {\n        +String id\n        +String email\n        +String name\n        +DateTime createdAt\n        +DateTime updatedAt\n        +login() bool\n        +logout() void\n        +updateProfile(data) User\n    }\n\n    class Organisation {\n        +String id\n        +String name\n        +String slug\n        +Plan plan\n        +getMembers() List~User~\n        +addMember(user) void\n        +removeMember(user) void\n    }\n\n    class Project {\n        +String id\n        +String name\n        +String description\n        +Status status\n        +DateTime deadline\n        +getTasks() List~Task~\n        +addTask(task) void\n        +archive() void\n    }\n\n    class Task {\n        +String id\n        +String title\n        +String description\n        +Priority priority\n        +Status status\n        +User assignee\n        +assign(user) void\n        +complete() void\n    }\n\n    class Comment {\n        +String id\n        +String content\n        +User author\n        +DateTime createdAt\n        +edit(content) void\n        +delete() void\n    }\n\n    %% Relationships\n    User \"1\" --> \"*\" Organisation : belongs to\n    Organisation \"1\" --> \"*\" Project : owns\n    Project \"1\" --> \"*\" Task : contains\n    User \"1\" --> \"*\" Task : assigned to\n    Task \"1\" --> \"*\" Comment : has\n    User \"1\" --> \"*\" Comment : writes\n\n    %% Enums\n    class Status {\n        <<enumeration>>\n        DRAFT\n        ACTIVE\n        COMPLETED\n        ARCHIVED\n    }\n\n    class Priority {\n        <<enumeration>>\n        LOW\n        MEDIUM\n        HIGH\n        CRITICAL\n    }\n\n    class Plan {\n        <<enumeration>>\n        FREE\n        PRO\n        ENTERPRISE\n    }\n",
