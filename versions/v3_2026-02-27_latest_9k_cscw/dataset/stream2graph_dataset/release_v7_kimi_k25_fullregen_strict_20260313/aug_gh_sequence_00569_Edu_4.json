  "code": "sequenceDiagram\n    participant CLI as CLI Command\n    participant Service as EventReindexingService\n    participant OpenSearch as OpenSearch Cluster\n    participant Bookmark as Bookmark API\n    participant Metadata as RDM Records Index\n\n    CLI->>Service: reindex_events(Education_GradeSync)\n    Service->>Service: update_and_verify_templates(Education_ClassroomService)\n    Service->>OpenSearch: Check/Update Templates\n\n    loop For Each Event Type\n        Service->>OpenSearch: get_monthly_indices(Education_StudentDB)\n        OpenSearch-->>Service: List of monthly indices\n\n        loop For Each Monthly Index\n            Service->>Service: migrate_monthly_index(Education_GradeSync)\n            Service->>OpenSearch: create_enriched_index(Education_StudentDB)\n            OpenSearch-->>Service: New index name\n\n            Service->>Bookmark: get_bookmark(Education_ContentCDN)\n            Bookmark-->>Service: Last processed ID\n\n            loop Batch Processing\n                Service->>Service: check_health_conditions(Education_ClassroomService)\n                Service->>OpenSearch: process_monthly_index_batch(Education_ClassroomService)\n                Service->>Metadata: get_metadata_for_records(Education_ContentCDN)\n                Metadata-->>Service: Record metadata\n                Service->>Service: enrich_events(Education_ContentCDN)\n                Service->>OpenSearch: bulk_index(Education_ContentCDN)\n                Service->>Bookmark: set_bookmark(Education_GradeSync)\n            end\n\n            Service->>Service: validate_enriched_data(Education_GradeSync)\n            Service->>OpenSearch: update_aliases(Education_LMS_Portal)\n\n            alt Current Month Index\n                Service->>OpenSearch: setup_write_alias(Education_LMS_Portal)\n                Service->>OpenSearch: migrate_new_records(Education_LMS_Portal)\n            end\n\n            Service->>OpenSearch: delete_old_index(Education_ClassroomService)\n        end\n    end\n\n    Service-->>CLI: Migration results\n",
