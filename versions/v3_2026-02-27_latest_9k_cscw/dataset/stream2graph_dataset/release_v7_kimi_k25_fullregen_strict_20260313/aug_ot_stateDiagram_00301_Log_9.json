      "role": "Diagram_Editor",
      "action_type": "execute",
      "utterance": "好的，我先搭建主体框架：Logistics_FleetManagement作为起始节点指向Idle，Idle通过Start Request进入Loading。",
      "elements_involved": [
        "Logistics_FleetManagement",
