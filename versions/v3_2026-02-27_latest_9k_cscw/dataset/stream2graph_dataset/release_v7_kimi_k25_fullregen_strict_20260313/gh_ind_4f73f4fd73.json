  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要画一个用户互动的状态流转图，核心场景是A看了B的资料，然后可能点赞，最后双向喜欢。起点应该是初始状态Idle。",
      "elements_involved": [
        "Idle",
