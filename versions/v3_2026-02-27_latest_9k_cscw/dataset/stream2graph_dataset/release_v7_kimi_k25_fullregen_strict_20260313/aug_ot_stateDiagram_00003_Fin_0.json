      "is_repair": false
    },
    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "不行，中间要加一层Validating状态做程序校验。Loading完成后进入Validating，校验通过才到Ready状态，不通过的话要走到Error状态。",
      "elements_involved": [
        "Loading",
        "Validating",
        "Ready",
        "Error",
        "Program Loaded",
