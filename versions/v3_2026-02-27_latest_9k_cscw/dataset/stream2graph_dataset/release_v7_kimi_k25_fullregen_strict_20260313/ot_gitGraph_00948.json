    {
      "turn_id": 3,
      "role": "Domain_Expert",
      "action_type": "confirm",
      "utterance": "对，branch1在最左是order 0，branch2是order 1，main是order 2，branch3在最右是order 3。这样视觉上比较平衡。",
      "elements_involved": [
        "branch1 order: 0",
