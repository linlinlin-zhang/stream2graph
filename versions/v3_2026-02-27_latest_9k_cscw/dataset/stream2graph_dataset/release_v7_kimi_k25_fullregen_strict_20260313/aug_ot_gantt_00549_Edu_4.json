  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为GradeSync系统做一个混合线程的甘特图，展示P1、P2、P3三个处理阶段的时间线。P1对应StudentDB，P2是LMS Portal，P3又回到StudentDB。时间轴用毫秒级精度。",
      "elements_involved": [
        "P1",
