      "role": "Diagram_Editor",
      "action_type": "clarify",
      "utterance": "明白，起点是群聊室连接到草稿状态。那草稿之后呢？是管理员发布后才变成可售状态吗？",
      "elements_involved": [
        "Draft",
        "Available",
        "Admin"
