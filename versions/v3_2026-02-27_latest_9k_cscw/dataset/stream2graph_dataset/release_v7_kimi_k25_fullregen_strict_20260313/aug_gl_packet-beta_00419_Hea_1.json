  "cscw_dialogue": [
    {
      "turn_id": 1,
      "role": "Domain_Expert",
      "action_type": "propose",
      "utterance": "我们需要为HealthTech项目设计一个TCP报文格式的示意图，重点是展示标准头部结构，但要在Options字段的位置嵌入我们的患者记录标识。",
